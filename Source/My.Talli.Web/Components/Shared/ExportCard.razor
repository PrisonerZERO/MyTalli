@inherits My.Talli.Web.ViewModels.Shared.ExportCardViewModel

<div class="export-card">
    <div class="export-card-head">
        <span class="export-card-label">@Label</span>
        <span class="export-card-count">@RowCount.ToString("N0") row@(RowCount == 1 ? "" : "s")</span>
    </div>
    <p class="export-card-desc">@Description</p>
    @if (RowCount > 0)
    {
        <a class="export-card-btn" href="@DownloadUrl" target="_blank" rel="noopener" download>
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" x2="12" y1="15" y2="3" />
            </svg>
            Download CSV
        </a>
    }
    else
    {
        <button class="export-card-btn export-card-btn-disabled" disabled aria-label="No @Label.ToLowerInvariant() rows in this range">
            No rows in range
        </button>
    }
</div>
