@inherits My.Talli.Web.ViewModels.Shared.UserProfileButtonViewModel

<div class="profile-menu-wrapper">
    <button aria-expanded="@IsUserMenuOpen" aria-haspopup="true" aria-label="User menu"
            class="profile-trigger" @onclick="ToggleUserMenu" @onclick:stopPropagation="true">
        @UserInitials
    </button>

    @if (IsUserMenuOpen)
    {
        <div class="profile-backdrop" @onclick="CloseUserMenu"></div>
        <div class="profile-dropdown" role="menu" aria-label="User menu">
            <div class="profile-dropdown-header">
                <div class="profile-avatar">@UserInitials</div>
                <div class="profile-user-info">
                    <div class="profile-user-name">@UserFullName</div>
                    <div class="profile-user-email">@UserEmail</div>
                </div>
            </div>
            <div class="profile-divider"></div>
            <a class="profile-item" href="my-plan" role="menuitem">
                <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2" />
                    <circle cx="12" cy="7" r="4" />
                </svg>
                My Plan
            </a>
            <a class="profile-item" href="suggestions" role="menuitem">
                <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
                </svg>
                Suggestions
            </a>
            <a class="profile-item" href="settings" role="menuitem">
                <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                    <circle cx="12" cy="12" r="3" />
                    <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" />
                </svg>
                Settings
            </a>
            <div class="profile-divider"></div>
            <a class="profile-item profile-sign-out" data-enhance-nav="false" href="/api/auth/logout" role="menuitem">
                <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                    <path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4" />
                    <polyline points="16 17 21 12 16 7" />
                    <line x1="21" x2="9" y1="12" y2="12" />
                </svg>
                Sign Out
            </a>
        </div>
    }
</div>
