@inherits LayoutComponentBase

<a href="#main" class="skip-link">Skip to main content</a>

<div class="page">
    <button class="mobile-hamburger" aria-label="Open menu">
        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><line x1="3" x2="21" y1="6" y2="6" /><line x1="3" x2="21" y1="12" y2="12" /><line x1="3" x2="21" y1="18" y2="18" /></svg>
    </button>

    <div class="mobile-backdrop"></div>

    <div class="sidebar">
        <NavMenu @rendermode="InteractiveServer" />
    </div>

    <main id="main">
        <article class="content">
            @Body
        </article>
        <footer class="site-footer" role="contentinfo">
            <p>&copy; @LayoutHelper.CurrentYear MyTalli v@(LayoutHelper.VersionNumber) &mdash; All rights reserved.</p>
            <a href="mailto:hello@mytalli.com">hello@mytalli.com</a>
        </footer>
    </main>
</div>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>
