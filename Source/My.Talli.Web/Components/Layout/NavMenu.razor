@inherits My.Talli.Web.ViewModels.Layout.NavMenuViewModel

<aside class="sidebar-inner" aria-label="Sidebar">
    <a class="sidebar-logo" href="/dashboard">My<span>Talli</span></a>

    <nav class="sidebar-nav" aria-label="Main navigation">
        <NavLink class="nav-link" href="dashboard" Match="NavLinkMatch.All">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <rect height="7" rx="1" width="7" x="3" y="3" />
                <rect height="7" rx="1" width="7" x="14" y="3" />
                <rect height="7" rx="1" width="7" x="3" y="14" />
                <rect height="7" rx="1" width="7" x="14" y="14" />
            </svg>
            Dashboard
        </NavLink>

        <NavLink class="nav-link" href="platforms">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <path d="M12 2L2 7l10 5 10-5-10-5z" />
                <path d="M2 17l10 5 10-5" />
                <path d="M2 12l10 5 10-5" />
            </svg>
            Platforms
        </NavLink>

        <NavLink class="nav-link" href="goals">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <path d="M12 6v6l4 2" />
            </svg>
            Goals
        </NavLink>

        <NavLink class="nav-link" href="export">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" x2="12" y1="15" y2="3" />
            </svg>
            Export
        </NavLink>

        <NavLink class="nav-link" href="suggestions">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z" />
            </svg>
            Suggestions
        </NavLink>

        <NavLink class="nav-link" href="settings">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="3" />
                <path d="M19.4 15a1.65 1.65 0 00.33 1.82l.06.06a2 2 0 010 2.83 2 2 0 01-2.83 0l-.06-.06a1.65 1.65 0 00-1.82-.33 1.65 1.65 0 00-1 1.51V21a2 2 0 01-4 0v-.09A1.65 1.65 0 009 19.4a1.65 1.65 0 00-1.82.33l-.06.06a2 2 0 01-2.83-2.83l.06-.06A1.65 1.65 0 004.68 15a1.65 1.65 0 00-1.51-1H3a2 2 0 010-4h.09A1.65 1.65 0 004.6 9a1.65 1.65 0 00-.33-1.82l-.06-.06a2 2 0 012.83-2.83l.06.06A1.65 1.65 0 009 4.68a1.65 1.65 0 001-1.51V3a2 2 0 014 0v.09a1.65 1.65 0 001 1.51 1.65 1.65 0 001.82-.33l.06-.06a2 2 0 012.83 2.83l-.06.06A1.65 1.65 0 0019.4 9a1.65 1.65 0 001.51 1H21a2 2 0 010 4h-.09a1.65 1.65 0 00-1.51 1z" />
            </svg>
            Settings
        </NavLink>

        <div class="nav-spacer"></div>
    </nav>

    <div class="upgrade-card">
        <h4>Upgrade to Pro</h4>
        <p>Unlimited platforms, full history, goals &amp; CSV export.</p>
        <a class="upgrade-btn" href="subscription">Manage Plan</a>
    </div>

    <div class="sidebar-user">
        <div class="user-avatar">@UserInitials</div>
        <div class="user-info">
            <div class="user-name">@UserFullName</div>
            <div class="user-email">@UserEmail</div>
        </div>
    </div>
</aside>
