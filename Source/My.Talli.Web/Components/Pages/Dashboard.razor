@page "/dashboard"
@inherits My.Talli.Web.ViewModels.Pages.DashboardViewModel
@rendermode InteractiveServer

<PageTitle>@PageTitle — MyTalli</PageTitle>

<!-- Swoosh hero -->
<div class="hero dash-hero">
    <div class="hero-bg" aria-hidden="true">
        <svg preserveAspectRatio="none" viewBox="0 0 1000 600" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="dashSwooshGrad" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#6c5ce7" />
                    <stop offset="50%" stop-color="#8b5cf6" />
                    <stop offset="100%" stop-color="#6c5ce7" />
                </linearGradient>
            </defs>
            <path d="M0,0 L1000,0 L1000,320 C850,400 650,280 450,340 C250,400 100,360 0,300 Z" fill="url(#dashSwooshGrad)" />
        </svg>
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>
        <div class="deco-circle deco-circle-3"></div>
    </div>

    <div class="hero-content hero-top top-bar animate-in delay-1">
        <div class="greeting">
            <h1>Good morning, @UserFirstName</h1>
            <p class="hero-subtitle">Here's how your revenue is looking.</p>
        </div>
        <ul class="hero-nav">
            <li>
                <div class="period-pills">
                    @foreach (var period in Periods)
                    {
                        <button aria-label="Filter by @period" class="pill @(period == ActivePeriod ? "active" : "")"
                                @onclick="async () => await SelectPeriod(period)">
                            @period
                        </button>
                    }
                </div>
            </li>
            <li><My.Talli.Web.Components.Shared.UserProfileButton @rendermode="InteractiveServer" /></li>
        </ul>
    </div>
</div>

<!-- Spoke tabs -->
<nav class="spoke-tabs" role="tablist" aria-label="Dashboard sections">
    <button class="spoke-tab @(ActiveTab == "overview" ? "active" : "")" role="tab" aria-selected="@(ActiveTab == "overview")" @onclick='() => SelectTab("overview")'>Overview</button>
    <button class="spoke-tab @(ActiveTab == "revenue" ? "active" : "")" role="tab" aria-selected="@(ActiveTab == "revenue")" @onclick='() => SelectTab("revenue")'>Revenue</button>
    <button class="spoke-tab @(ActiveTab == "expenses" ? "active" : "")" role="tab" aria-selected="@(ActiveTab == "expenses")" @onclick='() => SelectTab("expenses")'>Expenses</button>
    <button class="spoke-tab @(ActiveTab == "payouts" ? "active" : "")" role="tab" aria-selected="@(ActiveTab == "payouts")" @onclick='() => SelectTab("payouts")'>Payouts</button>
</nav>

<!-- Known issue banner -->
@if (ShowKnownIssue)
{
    <div class="known-issue-banner known-issue-@KnownIssueSeverity.ToLowerInvariant() animate-in delay-2" role="alert">
        <div class="known-issue-content">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <path d="M10.29 3.86L1.82 18a2 2 0 001.71 3h16.94a2 2 0 001.71-3L13.71 3.86a2 2 0 00-3.42 0z" />
                <line x1="12" x2="12" y1="9" y2="13" />
                <line x1="12" x2="12.01" y1="17" y2="17" />
            </svg>
            <span><strong>Known Issue:</strong> @KnownIssueMessage</span>
        </div>
    </div>
}

<!-- Sample data banner -->
@if (IsSampleData)
{
    <div class="sample-banner animate-in delay-2" role="status">
        <div class="sample-banner-content">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" x2="12" y1="8" y2="12" />
                <line x1="12" x2="12.01" y1="16" y2="16" />
            </svg>
            <span>You're viewing <strong>sample data</strong>. Connect a platform or activate Manual Entry to see your real revenue.</span>
        </div>
        <a class="sample-banner-cta" href="my-plan">Get started</a>
    </div>
}

@* ── OVERVIEW TAB ── *@
@if (ActiveTab == "overview")
{
    <!-- Summary cards -->
    <div class="summary-row animate-in delay-2">
        <div class="summary-card">
            <div class="card-label">Total Revenue</div>
            <div class="card-value">@TotalRevenue.ToString("C0")</div>
            <div class="card-badge">
                <svg aria-hidden="true" fill="none" viewBox="0 0 12 12">
                    <path d="M6 9V3M6 3L3 6M6 3l3 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" />
                </svg>
                @TotalRevenueChange vs last month
            </div>
        </div>
        <div class="summary-card">
            <div class="card-label">This Month</div>
            <div class="card-value">@ThisMonthRevenue.ToString("C0")</div>
            <div class="card-badge">
                <svg aria-hidden="true" fill="none" viewBox="0 0 12 12">
                    <path d="M6 9V3M6 3L3 6M6 3l3 3" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" />
                </svg>
                @ThisMonthChange vs last month
            </div>
        </div>
        <div class="summary-card">
            <div class="card-label">Platforms Connected</div>
            <div class="card-value">@PlatformsConnected</div>
            <div class="platform-dots">
                @foreach (var platform in Platforms)
                {
                    <div class="platform-dot-item">
                        <div aria-hidden="true" class="platform-dot" style="background:@platform.Color"></div>
                        <span class="platform-dot-label">@platform.Name</span>
                    </div>
                }
            </div>
        </div>
        <div class="summary-card">
            <div class="card-label">Monthly Goal</div>
            @if (HasGoal)
            {
                <div class="card-value">@(MonthlyGoalPercentage)%</div>
                <div class="mini-progress">
                    <div class="mini-progress-fill" style="width:@(MonthlyGoalPercentage)%"></div>
                </div>
                <div class="goal-label">@GoalCurrentAmount.ToString("C0") of @GoalTargetAmount.ToString("C0")</div>
                <a class="goal-set-link" href="goals">View goals &rarr;</a>
            }
            else
            {
                <div class="card-value">&mdash;</div>
                <a class="goal-set-link" href="goals">Set a goal &rarr;</a>
            }
        </div>
    </div>

    <!-- Revenue chart -->
    <div class="chart-card animate-in delay-3" role="img" aria-label="Revenue over time line chart showing current and previous period trends">
        <div class="chart-header">
            <h3>Revenue Over Time</h3>
            <div class="chart-legend">
                <div class="legend-item">
                    <div class="legend-dot" style="background:#6c5ce7"></div> Revenue
                </div>
                <div class="legend-item">
                    <div class="legend-dot" style="background:#e0dce8"></div> Previous period
                </div>
            </div>
        </div>
        <div class="chart-area">
            <svg preserveAspectRatio="none" viewBox="0 0 800 200">
                <defs>
                    <linearGradient id="chartGrad" x1="0" x2="0" y1="0" y2="1">
                        <stop offset="0%" stop-color="#6c5ce7" stop-opacity="0.25" />
                        <stop offset="100%" stop-color="#6c5ce7" stop-opacity="0.02" />
                    </linearGradient>
                    <linearGradient id="prevGrad" x1="0" x2="0" y1="0" y2="1">
                        <stop offset="0%" stop-color="#e0dce8" stop-opacity="0.15" />
                        <stop offset="100%" stop-color="#e0dce8" stop-opacity="0.02" />
                    </linearGradient>
                </defs>

                <!-- Grid lines -->
                <g class="chart-grid">
                    <line x1="0" x2="800" y1="40" y2="40" />
                    <line x1="0" x2="800" y1="80" y2="80" />
                    <line x1="0" x2="800" y1="120" y2="120" />
                    <line x1="0" x2="800" y1="160" y2="160" />
                </g>

                <!-- Y-axis labels -->
                <text class="chart-label" x="0" y="38">$200</text>
                <text class="chart-label" x="0" y="78">$150</text>
                <text class="chart-label" x="0" y="118">$100</text>
                <text class="chart-label" x="0" y="158">$50</text>

                <!-- Previous period -->
                <path d="@ChartPreviousAreaPath" fill="url(#prevGrad)" />
                <path d="@ChartPreviousLinePath" fill="none" stroke="#e0dce8" stroke-width="2" />

                <!-- Current period -->
                <path d="@ChartCurrentAreaPath" fill="url(#chartGrad)" />
                <path d="@ChartCurrentLinePath" fill="none" stroke="#6c5ce7" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" />

                <!-- Current value dot -->
                <circle cx="796" cy="32" fill="#6c5ce7" r="5" />
                <circle cx="796" cy="32" fill="#6c5ce7" opacity="0.2" r="8" />

                <!-- X-axis labels -->
                <text class="chart-label" x="40" y="196">Feb 1</text>
                <text class="chart-label" x="175" y="196">Feb 6</text>
                <text class="chart-label" x="310" y="196">Feb 11</text>
                <text class="chart-label" x="445" y="196">Feb 16</text>
                <text class="chart-label" x="580" y="196">Feb 21</text>
                <text class="chart-label" x="715" y="196">Feb 26</text>
            </svg>
        </div>
    </div>

    <!-- Two-column: Platform Breakdown + Revenue Goal -->
    <div class="animate-in delay-4 two-col">
        <!-- Platform Breakdown -->
        <div class="section-card">
            <h3>Platform Breakdown</h3>
            @foreach (var platform in Platforms)
            {
                <div class="platform-row">
                    <div class="platform-color-dot" style="background:@platform.Color"></div>
                    <div class="platform-name">@platform.Name</div>
                    <div class="platform-bar-track">
                        <div class="platform-bar-fill" style="background:@platform.Color; width:@(platform.Percentage)%"></div>
                    </div>
                    <div class="platform-amount">@platform.Amount.ToString("C0")</div>
                    <div class="platform-pct">@(platform.Percentage)%</div>
                </div>
            }
        </div>

        <!-- Revenue Goal -->
        <div class="section-card">
            <h3>Revenue Goal</h3>
            @if (HasGoal)
            {
                <div class="goal-center">
                    <div class="circle-progress">
                        <svg viewBox="0 0 140 140">
                            <defs>
                                <linearGradient id="goalGrad" x1="0" x2="1" y1="0" y2="1">
                                    <stop offset="0%" stop-color="#6c5ce7" />
                                    <stop offset="100%" stop-color="#8b5cf6" />
                                </linearGradient>
                            </defs>
                            <circle class="circle-bg" cx="70" cy="70" r="58" />
                            <circle class="circle-fill" cx="70" cy="70" r="58"
                                    style="stroke-dasharray:@CircleStrokeDasharray; stroke-dashoffset:@CircleStrokeDashoffset" />
                        </svg>
                        <div class="circle-text">
                            <span class="circle-pct">@(GoalPercentage)%</span>
                            <span class="circle-sub">completed</span>
                        </div>
                    </div>
                    <div class="goal-amounts">@GoalCurrentAmount.ToString("C0") <span>/ @GoalTargetAmount.ToString("C0")</span></div>
                    <div class="goal-target">Monthly Target</div>
                    <div class="goal-status @(GoalOnTrack ? "goal-on-track" : "goal-behind")">
                        @if (GoalOnTrack)
                        {
                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M22 11.08V12a10 10 0 11-5.93-9.14" />
                                <polyline points="22 4 12 14.01 9 11.01" />
                            </svg>
                            <span>On track &mdash; @DaysRemaining days left</span>
                        }
                        else
                        {
                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                                <circle cx="12" cy="12" r="10" />
                                <line x1="12" x2="12" y1="8" y2="12" />
                                <line x1="12" x2="12.01" y1="16" y2="16" />
                            </svg>
                            <span>Behind pace &mdash; @DaysRemaining days left</span>
                        }
                    </div>
                    <a class="goal-set-link" href="goals">View goals &rarr;</a>
                </div>
            }
            else
            {
                <div class="goal-center goal-empty">
                    <svg aria-hidden="true" fill="none" height="48" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="48">
                        <circle cx="12" cy="12" r="10" />
                        <path d="M12 6v6l4 2" />
                    </svg>
                    <p>No monthly goal set yet.</p>
                    <a class="goal-set-link" href="goals">Set a goal &rarr;</a>
                </div>
            }
        </div>
    </div>

    <!-- Recent Transactions -->
    <div class="animate-in delay-5 transactions-card">
        <div class="transactions-header">
            <h3>Recent Transactions</h3>
            <button aria-label="View all transactions" class="view-all" @onclick='() => SelectTab("revenue")'>View all &rarr;</button>
        </div>
        <table class="tx-table">
            <thead>
                <tr>
                    <th>Platform</th>
                    <th>Description</th>
                    <th>Date</th>
                    <th>Amount</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tx in RecentTransactions.Take(5))
                {
                    <tr>
                        <td>
                            <div class="tx-platform">
                                <div class="tx-dot" style="background:@tx.PlatformColor"></div>
                                <span class="tx-platform-name">@tx.PlatformName</span>
                            </div>
                        </td>
                        <td>@tx.Description</td>
                        <td>@tx.Date</td>
                        <td>@tx.Amount.ToString("C2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@* ── REVENUE TAB ── *@
@if (ActiveTab == "revenue")
{
    <div class="dash-tab-content animate-in delay-2" role="tabpanel" aria-label="Revenue">
        <div class="transactions-card">
            <div class="transactions-header">
                <h3>All Revenue</h3>
            </div>
            <table class="tx-table @DensityCss">
                <thead>
                    <tr>
                        <th class="dash-th-sort" @onclick='() => RevenueSortBy("Platform")'>Platform <span class="dash-sort-ind" aria-hidden="true">@GetRevenueSortIndicator("Platform")</span></th>
                        <th class="dash-th-sort" @onclick='() => RevenueSortBy("Description")'>Description <span class="dash-sort-ind" aria-hidden="true">@GetRevenueSortIndicator("Description")</span></th>
                        <th class="dash-th-sort" @onclick='() => RevenueSortBy("TransactionDate")'>Date <span class="dash-sort-ind" aria-hidden="true">@GetRevenueSortIndicator("TransactionDate")</span></th>
                        <th class="dash-th-sort tx-th-right" @onclick='() => RevenueSortBy("Amount")'>Amount <span class="dash-sort-ind" aria-hidden="true">@GetRevenueSortIndicator("Amount")</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var tx in PagedRevenueTransactions)
                    {
                        <tr>
                            <td>
                                <div class="tx-platform">
                                    <div class="tx-dot" style="background:@tx.PlatformColor"></div>
                                    <span class="tx-platform-name">@tx.PlatformName</span>
                                </div>
                            </td>
                            <td>@tx.Description</td>
                            <td>@tx.Date</td>
                            <td class="tx-td-amount revenue">@tx.Amount.ToString("C2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (RecentTransactions.Count > 0)
        {
        <div class="dash-pagination">
            <div class="dash-page-size">
                <label for="rev-page-select">Show</label>
                <select class="dash-page-select" id="rev-page-select" @bind="PageSize" @bind:after="ChangePageSize">
                    @foreach (var size in PageSizeOptions)
                    {
                        <option value="@size">@size</option>
                    }
                </select>
                <span>entries</span>
            </div>
            <div class="dash-density" role="group" aria-label="Row density">
                <button class="dash-density-btn @(Density == "compact" ? "active" : "")" aria-pressed="@(Density == "compact")" title="Compact" @onclick='() => SetDensity("compact")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="6" y2="6" /><line x1="2" x2="14" y1="9" y2="9" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
                <button class="dash-density-btn @(Density == "comfortable" ? "active" : "")" aria-pressed="@(Density == "comfortable")" title="Comfortable" @onclick='() => SetDensity("comfortable")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="8" y2="8" /><line x1="2" x2="14" y1="13" y2="13" /></svg>
                </button>
                <button class="dash-density-btn @(Density == "spacious" ? "active" : "")" aria-pressed="@(Density == "spacious")" title="Spacious" @onclick='() => SetDensity("spacious")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="4" y2="4" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
            </div>
            <span class="dash-page-info">@((RevenueCurrentPage - 1) * PageSize + 1)–@Math.Min(RevenueCurrentPage * PageSize, RecentTransactions.Count) of @RecentTransactions.Count</span>
            <div class="dash-page-nav" role="group" aria-label="Pagination">
                <button class="dash-page-btn" disabled="@(RevenueCurrentPage <= 1)" @onclick="() => RevenueGoToPage(RevenueCurrentPage - 1)" aria-label="Previous page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <button class="dash-page-btn" disabled="@(RevenueCurrentPage >= TotalRevenuePages)" @onclick="() => RevenueGoToPage(RevenueCurrentPage + 1)" aria-label="Next page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                </button>
            </div>
        </div>
        }
    </div>
}

@* ── EXPENSES TAB ── *@
@if (ActiveTab == "expenses")
{
    <div class="dash-tab-content animate-in delay-2" role="tabpanel" aria-label="Expenses">
        <div class="transactions-card">
            <div class="transactions-header">
                <h3>All Expenses</h3>
            </div>
            <table class="tx-table @DensityCss">
                <thead>
                    <tr>
                        <th class="dash-th-sort" @onclick='() => ExpenseSortBy("Platform")'>Platform <span class="dash-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("Platform")</span></th>
                        <th class="dash-th-sort" @onclick='() => ExpenseSortBy("Description")'>Description <span class="dash-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("Description")</span></th>
                        <th class="dash-th-sort" @onclick='() => ExpenseSortBy("Category")'>Category <span class="dash-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("Category")</span></th>
                        <th class="dash-th-sort" @onclick='() => ExpenseSortBy("ExpenseDate")'>Date <span class="dash-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("ExpenseDate")</span></th>
                        <th class="dash-th-sort tx-th-right" @onclick='() => ExpenseSortBy("Amount")'>Amount <span class="dash-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("Amount")</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var expense in PagedExpenses)
                    {
                        <tr>
                            <td>
                                <div class="tx-platform">
                                    <div class="tx-dot" style="background:@expense.PlatformColor"></div>
                                    <span class="tx-platform-name">@expense.Platform</span>
                                </div>
                            </td>
                            <td>@expense.Description</td>
                            <td><span class="dash-cat-tag">@expense.Category</span></td>
                            <td>@expense.ExpenseDateLabel</td>
                            <td class="tx-td-amount expense">-@expense.Amount.ToString("C2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Expenses.Count > 0)
        {
        <div class="dash-pagination">
            <div class="dash-page-size">
                <label for="exp-page-select">Show</label>
                <select class="dash-page-select" id="exp-page-select" @bind="PageSize" @bind:after="ChangePageSize">
                    @foreach (var size in PageSizeOptions)
                    {
                        <option value="@size">@size</option>
                    }
                </select>
                <span>entries</span>
            </div>
            <div class="dash-density" role="group" aria-label="Row density">
                <button class="dash-density-btn @(Density == "compact" ? "active" : "")" aria-pressed="@(Density == "compact")" title="Compact" @onclick='() => SetDensity("compact")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="6" y2="6" /><line x1="2" x2="14" y1="9" y2="9" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
                <button class="dash-density-btn @(Density == "comfortable" ? "active" : "")" aria-pressed="@(Density == "comfortable")" title="Comfortable" @onclick='() => SetDensity("comfortable")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="8" y2="8" /><line x1="2" x2="14" y1="13" y2="13" /></svg>
                </button>
                <button class="dash-density-btn @(Density == "spacious" ? "active" : "")" aria-pressed="@(Density == "spacious")" title="Spacious" @onclick='() => SetDensity("spacious")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="4" y2="4" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
            </div>
            <span class="dash-page-info">@((ExpenseCurrentPage - 1) * PageSize + 1)–@Math.Min(ExpenseCurrentPage * PageSize, Expenses.Count) of @Expenses.Count</span>
            <div class="dash-page-nav" role="group" aria-label="Pagination">
                <button class="dash-page-btn" disabled="@(ExpenseCurrentPage <= 1)" @onclick="() => ExpenseGoToPage(ExpenseCurrentPage - 1)" aria-label="Previous page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <button class="dash-page-btn" disabled="@(ExpenseCurrentPage >= TotalExpensePages)" @onclick="() => ExpenseGoToPage(ExpenseCurrentPage + 1)" aria-label="Next page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                </button>
            </div>
        </div>
        }
    </div>
}

@* ── PAYOUTS TAB ── *@
@if (ActiveTab == "payouts")
{
    <div class="dash-tab-content animate-in delay-2" role="tabpanel" aria-label="Payouts">
        <div class="transactions-card">
            <div class="transactions-header">
                <h3>All Payouts</h3>
            </div>
            <table class="tx-table @DensityCss">
                <thead>
                    <tr>
                        <th class="dash-th-sort" @onclick='() => PayoutSortBy("Platform")'>Platform <span class="dash-sort-ind" aria-hidden="true">@GetPayoutSortIndicator("Platform")</span></th>
                        <th class="dash-th-sort" @onclick='() => PayoutSortBy("PayoutDate")'>Date <span class="dash-sort-ind" aria-hidden="true">@GetPayoutSortIndicator("PayoutDate")</span></th>
                        <th class="dash-th-sort tx-th-right" @onclick='() => PayoutSortBy("Amount")'>Amount <span class="dash-sort-ind" aria-hidden="true">@GetPayoutSortIndicator("Amount")</span></th>
                        <th class="dash-th-sort" @onclick='() => PayoutSortBy("Status")'>Status <span class="dash-sort-ind" aria-hidden="true">@GetPayoutSortIndicator("Status")</span></th>
                        <th class="dash-th-sort" @onclick='() => PayoutSortBy("ExpectedArrival")'>Expected Arrival <span class="dash-sort-ind" aria-hidden="true">@GetPayoutSortIndicator("ExpectedArrival")</span></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var payout in PagedPayouts)
                    {
                        <tr>
                            <td>
                                <div class="tx-platform">
                                    <div class="tx-dot" style="background:@payout.PlatformColor"></div>
                                    <span class="tx-platform-name">@payout.Platform</span>
                                </div>
                            </td>
                            <td>@payout.PayoutDateLabel</td>
                            <td class="tx-td-amount payout">@payout.Amount.ToString("C2")</td>
                            <td><span class="payout-status @payout.StatusCss">@payout.Status</span></td>
                            <td>@payout.ExpectedArrivalLabel</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
        @if (Payouts.Count > 0)
        {
        <div class="dash-pagination">
            <div class="dash-page-size">
                <label for="pay-page-select">Show</label>
                <select class="dash-page-select" id="pay-page-select" @bind="PageSize" @bind:after="ChangePageSize">
                    @foreach (var size in PageSizeOptions)
                    {
                        <option value="@size">@size</option>
                    }
                </select>
                <span>entries</span>
            </div>
            <div class="dash-density" role="group" aria-label="Row density">
                <button class="dash-density-btn @(Density == "compact" ? "active" : "")" aria-pressed="@(Density == "compact")" title="Compact" @onclick='() => SetDensity("compact")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="6" y2="6" /><line x1="2" x2="14" y1="9" y2="9" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
                <button class="dash-density-btn @(Density == "comfortable" ? "active" : "")" aria-pressed="@(Density == "comfortable")" title="Comfortable" @onclick='() => SetDensity("comfortable")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="8" y2="8" /><line x1="2" x2="14" y1="13" y2="13" /></svg>
                </button>
                <button class="dash-density-btn @(Density == "spacious" ? "active" : "")" aria-pressed="@(Density == "spacious")" title="Spacious" @onclick='() => SetDensity("spacious")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="4" y2="4" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
            </div>
            <span class="dash-page-info">@((PayoutCurrentPage - 1) * PageSize + 1)–@Math.Min(PayoutCurrentPage * PageSize, Payouts.Count) of @Payouts.Count</span>
            <div class="dash-page-nav" role="group" aria-label="Pagination">
                <button class="dash-page-btn" disabled="@(PayoutCurrentPage <= 1)" @onclick="() => PayoutGoToPage(PayoutCurrentPage - 1)" aria-label="Previous page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <button class="dash-page-btn" disabled="@(PayoutCurrentPage >= TotalPayoutPages)" @onclick="() => PayoutGoToPage(PayoutCurrentPage + 1)" aria-label="Next page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                </button>
            </div>
        </div>
        }
    </div>
}
