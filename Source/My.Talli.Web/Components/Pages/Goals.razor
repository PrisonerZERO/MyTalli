@page "/goals"
@inherits My.Talli.Web.ViewModels.Pages.GoalsViewModel
@rendermode InteractiveServer

<PageTitle>Goals — MyTalli</PageTitle>

<!-- SVG gradient for circle progress (must be in DOM) -->
<svg aria-hidden="true" style="height:0;position:absolute;width:0;">
    <defs>
        <linearGradient id="goalGradient" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#6c5ce7" />
            <stop offset="100%" stop-color="#8b5cf6" />
        </linearGradient>
    </defs>
</svg>

<!-- Swoosh hero -->
<section class="hero goals-hero" aria-label="Your goals overview">
    <div class="hero-bg" aria-hidden="true">
        <svg preserveAspectRatio="none" viewBox="0 0 1000 600" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="goalsSwooshGrad" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#6c5ce7" />
                    <stop offset="50%" stop-color="#8b5cf6" />
                    <stop offset="100%" stop-color="#6c5ce7" />
                </linearGradient>
            </defs>
            <path d="M0,0 L1000,0 L1000,320 C850,400 650,280 450,340 C250,400 100,360 0,300 Z" fill="url(#goalsSwooshGrad)" />
        </svg>
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>
        <div class="deco-circle deco-circle-3"></div>
    </div>

    <div class="hero-content">
        <div class="hero-top">
            <div>
                <h1>Your Goals</h1>
                <p class="hero-subtitle">Set targets for what matters. Track them all in one place.</p>
            </div>
            <ul class="hero-nav">
                @if (!IsSampleData)
                {
                    <li>
                        <button class="hero-action-btn" @onclick="OpenAddForm" aria-label="Create a new goal">
                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24">
                                <line x1="12" x2="12" y1="5" y2="19" />
                                <line x1="5" x2="19" y1="12" y2="12" />
                            </svg>
                            New Goal
                        </button>
                    </li>
                }
                <li><My.Talli.Web.Components.Shared.UserProfileButton @rendermode="InteractiveServer" /></li>
            </ul>
        </div>

        <div class="hero-stats" role="group" aria-label="Goal statistics">
            <div class="hero-stat">
                <span class="hero-stat-num">@ActiveGoalCount</span>
                <span class="hero-stat-label">Active Goals</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-num">@OnTrackCount</span>
                <span class="hero-stat-label">On Track</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-num">@TotalEarned</span>
                <span class="hero-stat-label">Total Earned</span>
            </div>
        </div>
    </div>
</section>

<!-- Sample data banner -->
@if (IsSampleData)
{
    <div class="sample-banner animate-in delay-2" role="status">
        <div class="sample-banner-content">
            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                <circle cx="12" cy="12" r="10" />
                <line x1="12" x2="12" y1="8" y2="12" />
                <line x1="12" x2="12.01" y1="16" y2="16" />
            </svg>
            <span>You're viewing <strong>sample data</strong>. Connect a platform or activate a module to see your real revenue.</span>
        </div>
        <div class="sample-banner-actions">
            <a class="sample-banner-cta" href="platforms">Connect a platform</a>
            <a class="sample-banner-cta sample-banner-cta-secondary" href="my-plan">Activate Manual Entry</a>
        </div>
    </div>
}

@if (IsLoading)
{
    <section class="goals-loading-card animate-in delay-1" aria-label="Loading goals">
        <div class="goals-loading" role="status">
            <p>Loading your goals...</p>
        </div>
    </section>
}
else
{
    <div class="goals-grid animate-in delay-2">
        @foreach (var goal in Goals)
        {
            @if (!IsSampleData && goal.Id == EditingGoalId)
            {
                @* ── Inline edit form card ── *@
                <article class="goals-card goals-form-card" aria-label="Editing @goal.Name goal">
                    <div class="goals-form-body">
                        <div class="goals-form-group">
                            <label class="goals-form-label">Goal Type</label>
                            <select class="goals-form-select" @bind="FormGoalTypeId">
                                @foreach (var gt in GoalTypes)
                                {
                                    <option value="@gt.Id">@gt.Name</option>
                                }
                            </select>
                        </div>
                        <div class="goals-form-group">
                            <label class="goals-form-label">Platform</label>
                            <select class="goals-form-select" @bind="FormPlatform">
                                <option value="">All Platforms</option>
                                @foreach (var platform in AvailablePlatforms)
                                {
                                    <option value="@platform">@platform</option>
                                }
                            </select>
                        </div>
                        <div class="goals-form-group">
                            <label class="goals-form-label">Target Amount</label>
                            <input class="goals-form-input" type="number" step="0.01" min="0" placeholder="0.00" @bind="FormTargetAmount" />
                        </div>
                        <div class="goals-form-row">
                            <div class="goals-form-group goals-form-half">
                                <label class="goals-form-label">Start Date</label>
                                <input class="goals-form-input" type="date" @bind="FormStartDate" />
                            </div>
                            <div class="goals-form-group goals-form-half">
                                <label class="goals-form-label">End Date</label>
                                <input class="goals-form-input" type="date" @bind="FormEndDate" />
                            </div>
                        </div>
                    </div>
                    <div class="goals-form-preview">
                        @if (FormHasMatchingRevenue)
                        {
                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                            <span><strong>@FormMatchingRevenue.ToString("C2")</strong> in matching revenue</span>
                        }
                        else
                        {
                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" x2="12" y1="8" y2="12" /><line x1="12" x2="12.01" y1="16" y2="16" /></svg>
                            <span>No revenue found for this date range</span>
                        }
                    </div>
                    <div class="goals-card-bottom goals-form-actions">
                        <button class="goals-cancel-btn" @onclick="CancelForm">Cancel</button>
                        <button class="goals-save-btn" @onclick="SaveAsync" disabled="@(FormTargetAmount <= 0)">Save</button>
                    </div>
                </article>
            }
            else
            {
                @* ── Display card ── *@
                <article class="goals-card" aria-label="@goal.Name goal, @goal.Percentage percent complete">
                    <div class="goals-card-top">
                        <!-- Circle progress -->
                        <div class="goals-circle-wrap" aria-hidden="true">
                            <svg viewBox="0 0 140 140">
                                <circle class="goals-circle-bg" cx="70" cy="70" r="54" />
                                <circle class="goals-circle-fill" cx="70" cy="70" r="54"
                                        style="stroke-dasharray: 339.3; stroke-dashoffset: @((339.3 * (100 - Math.Min(goal.Percentage, 100)) / 100).ToString("F1"));" />
                            </svg>
                            <div class="goals-circle-inner">
                                <span class="goals-circle-pct">@goal.Percentage%</span>
                            </div>
                        </div>

                        <!-- Goal info -->
                        <div class="goals-card-info">
                            <div class="goals-card-label">@goal.Label</div>
                            <div class="goals-card-name">@goal.Name</div>
                            <div class="goals-card-amounts">@goal.Earned.ToString("C0") <span>/ @goal.Target.ToString("C0")</span></div>
                            <div class="goals-card-badge-wrap">
                                <span class="goals-badge @goal.StatusCss">@goal.Status</span>
                            </div>
                            @if (!IsSampleData && goal.Earned == 0)
                            {
                                <div class="goals-card-hint">No revenue matches this date range</div>
                            }
                        </div>
                    </div>
                    <div class="goals-card-bottom">
                        <div class="goals-card-days"><strong>@goal.DaysRemaining</strong> days remaining</div>
                        @if (!IsSampleData)
                        {
                            <div class="goals-card-actions">
                                <button class="goals-delete-btn" @onclick="() => DeleteGoal(goal.Id)" aria-label="Delete @goal.Name goal">Delete</button>
                                <button class="goals-edit-btn" @onclick="() => StartEdit(goal.Id)" aria-label="Edit @goal.Name goal">Edit &rarr;</button>
                            </div>
                        }
                    </div>
                </article>
            }
        }

        @if (!IsSampleData)
        {
            @if (ShowAddForm)
            {
                @* ── Inline add form card ── *@
                <article class="goals-card goals-form-card" aria-label="Add a new goal">
                    <div class="goals-form-body">
                        <div class="goals-form-group">
                            <label class="goals-form-label">Goal Type</label>
                            <select class="goals-form-select" @bind="FormGoalTypeId">
                                @foreach (var gt in GoalTypes)
                                {
                                    <option value="@gt.Id">@gt.Name</option>
                                }
                            </select>
                        </div>
                        <div class="goals-form-group">
                            <label class="goals-form-label">Platform</label>
                            <select class="goals-form-select" @bind="FormPlatform">
                                <option value="">All Platforms</option>
                                @foreach (var platform in AvailablePlatforms)
                                {
                                    <option value="@platform">@platform</option>
                                }
                            </select>
                        </div>
                        <div class="goals-form-group">
                            <label class="goals-form-label">Target Amount</label>
                            <input class="goals-form-input" type="number" step="0.01" min="0" placeholder="0.00" @bind="FormTargetAmount" />
                        </div>
                        <div class="goals-form-row">
                            <div class="goals-form-group goals-form-half">
                                <label class="goals-form-label">Start Date</label>
                                <input class="goals-form-input" type="date" @bind="FormStartDate" />
                            </div>
                            <div class="goals-form-group goals-form-half">
                                <label class="goals-form-label">End Date</label>
                                <input class="goals-form-input" type="date" @bind="FormEndDate" />
                            </div>
                        </div>
                    </div>
                    <div class="goals-form-preview">
                        @if (FormHasMatchingRevenue)
                        {
                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><path d="M22 11.08V12a10 10 0 11-5.93-9.14" /><polyline points="22 4 12 14.01 9 11.01" /></svg>
                            <span><strong>@FormMatchingRevenue.ToString("C2")</strong> in matching revenue</span>
                        }
                        else
                        {
                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" x2="12" y1="8" y2="12" /><line x1="12" x2="12.01" y1="16" y2="16" /></svg>
                            <span>No revenue found for this date range</span>
                        }
                    </div>
                    <div class="goals-card-bottom goals-form-actions">
                        <button class="goals-cancel-btn" @onclick="CancelForm">Cancel</button>
                        <button class="goals-save-btn" @onclick="SaveAsync" disabled="@(FormTargetAmount <= 0)">Save</button>
                    </div>
                </article>
            }
            else
            {
                @* ── Add new goal card ── *@
                <div class="goals-add-card" role="button" tabindex="0" @onclick="OpenAddForm" aria-label="Add a new goal">
                    <div class="goals-add-icon" aria-hidden="true">
                        <svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                            <line x1="12" x2="12" y1="5" y2="19" />
                            <line x1="5" x2="19" y1="12" y2="12" />
                        </svg>
                    </div>
                    <div class="goals-add-text">Add a new goal</div>
                </div>
            }
        }
    </div>
}

<!-- Delete confirmation -->
<ConfirmDialog Visible="DeletingGoalId.HasValue" ConfirmStyle="danger" OnConfirm="ConfirmDeleteAsync" OnCancel="CancelDelete">
    <svg aria-hidden="true" fill="none" height="40" stroke="#e74c3c" stroke-linecap="round" stroke-width="1.5" viewBox="0 0 24 24" width="40">
        <polyline points="3 6 5 6 21 6" />
        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
    </svg>
    <h2>Delete Goal?</h2>
    <p>Are you sure you want to delete <strong>@DeletingGoalDescription</strong>? This cannot be undone.</p>
</ConfirmDialog>
