@page "/"
@layout Layout.LandingLayout
@inherits My.Talli.Web.ViewModels.Pages.LandingPageViewModel
@rendermode InteractiveServer

<PageTitle>MyTalli — All Your Side Hustle Revenue, One Dashboard</PageTitle>

<a href="#main" class="skip-link">Skip to main content</a>

@if (ShowSignedOutToast)
{
    <div class="signout-toast">
        <svg class="signout-toast-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14" />
            <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
        @if (!string.IsNullOrEmpty(SignedOutName))
        {
            <span>You've been signed out, @SignedOutName. See you next time!</span>
        }
        else
        {
            <span>You've been signed out. See you next time!</span>
        }
        <button class="signout-toast-dismiss" @onclick="DismissToast">&times;</button>
    </div>
}

<!-- NAV -->
<nav id="landing-nav" aria-label="Main navigation">
    <a href="" class="logo" aria-label="MyTalli, go to top of page" @onclick="ScrollToTop" @onclick:preventDefault>My<span>Talli</span></a>
    <ul>
        <li><a href="" @onclick='() => ScrollToSection("how")' @onclick:preventDefault>How It Works</a></li>
        <li><a href="" @onclick='() => ScrollToSection("features")' @onclick:preventDefault>Features</a></li>
        <li><a href="" @onclick='() => ScrollToSection("pricing")' @onclick:preventDefault>Pricing</a></li>
    </ul>
    <a class="nav-cta" href="/signin">Get Early Access</a>
</nav>

<!-- HERO -->
<main id="main">
<section class="hero" aria-label="Hero">
    <div class="hero-bg-shape" aria-hidden="true">
        <svg viewBox="0 0 1000 1000" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="blobGrad" x1="0" y1="0" x2="1" y2="1">
                    <stop offset="0%" stop-color="#6c5ce7"/>
                    <stop offset="50%" stop-color="#8b5cf6"/>
                    <stop offset="100%" stop-color="#6c5ce7"/>
                </linearGradient>
            </defs>
            <path fill="url(#blobGrad)" d="
                M 450,0
                L 1000,0
                L 1000,1000
                L 450,1000
                C 400,900 310,750 280,500
                C 250,250 360,100 450,0
                Z
            "/>
        </svg>
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>
        <div class="deco-circle deco-circle-3"></div>
        <div class="deco-circle deco-circle-4"></div>
    </div>
    <div class="hero-left">
        <span class="hero-tag">Coming Soon</span>
        <h1>All your side&nbsp;hustle income. <em>One&nbsp;dashboard.</em></h1>
        <p>Connect <span class="p-stripe">Stripe</span>, <span class="p-etsy">Etsy</span>, <span class="p-gumroad">Gumroad</span>, and more — see exactly how much you're earning across every platform, updated in real time.</p>
        <a class="waitlist-btn" href="/signin">Join Waitlist</a>
        <p class="hero-note">Free to start. No credit card needed.</p>
    </div>
    <div class="hero-right">
        <div class="dash-mockup" role="img" aria-label="Dashboard preview showing $4,218 total revenue from Stripe, Etsy, and Gumroad with a 23% increase over last month">
            <div class="dash-header">
                <h3>Revenue Overview</h3>
                <span class="dash-period">Last 30 days</span>
            </div>
            <div class="dash-total">$4,218</div>
            <div class="dash-change">↑ 23% vs last month</div>
            <div class="dash-chart">
                <div class="dash-bar" style="height:40%"></div>
                <div class="dash-bar" style="height:55%"></div>
                <div class="dash-bar" style="height:35%"></div>
                <div class="dash-bar" style="height:70%"></div>
                <div class="dash-bar" style="height:60%"></div>
                <div class="dash-bar" style="height:85%"></div>
                <div class="dash-bar" style="height:50%"></div>
                <div class="dash-bar" style="height:95%"></div>
                <div class="dash-bar" style="height:75%"></div>
                <div class="dash-bar" style="height:65%"></div>
            </div>
            <div class="dash-platforms">
                <div class="dash-plat">
                    <span class="dash-plat-name"><span class="dash-plat-dot" style="background:#6c5ce7"></span>Stripe</span>
                    <span class="dash-plat-amt">$2,340</span>
                </div>
                <div class="dash-plat">
                    <span class="dash-plat-name"><span class="dash-plat-dot" style="background:#f97316"></span>Etsy</span>
                    <span class="dash-plat-amt">$1,128</span>
                </div>
                <div class="dash-plat">
                    <span class="dash-plat-name"><span class="dash-plat-dot" style="background:#ec4899"></span>Gumroad</span>
                    <span class="dash-plat-amt">$750</span>
                </div>
            </div>
        </div>
    </div>
    <div class="wave-divider" aria-hidden="true">
        <svg viewBox="0 0 1440 80" preserveAspectRatio="none">
            <path fill="#f8f7fc" d="M0,40 C360,80 720,0 1080,40 C1260,60 1380,50 1440,40 L1440,80 L0,80 Z"/>
        </svg>
    </div>
</section>

<!-- HOW IT WORKS -->
<section class="how-section" id="how" aria-labelledby="how-heading">
    <div class="section-tag" aria-hidden="true">How It Works</div>
    <h2 id="how-heading">Three steps. Total clarity.</h2>
    <p>No spreadsheets, no mental math. Just connect your platforms and let MyTalli handle the rest.</p>
    <div class="steps">
        <div class="step" aria-label="Step 1: Connect your platforms">
            <div class="step-num" aria-hidden="true">01</div>
            <h3>Connect your platforms</h3>
            <p>Link <span class="p-stripe">Stripe</span>,
                <span class="p-etsy">Etsy</span>,
                <span class="p-gumroad">Gumroad</span>,
                <span class="p-paypal">PayPal</span>,
                <span class="p-shopify">Shopify</span> — whatever you use. 
                <strong>Secure OAuth</strong> connects your platforms without exposing credentials.
                <strong>Encryption-At-Rest</strong> keeps your data protected even at the storage level.
                <strong>Sign-in</strong> with <strong>Google</strong>, <strong>Apple</strong>, or <strong>Microsoft</strong> — we never store or manage passwords.
            </p>
        </div>
        <div class="step" aria-label="Step 2: See the full picture">
            <div class="step-num" aria-hidden="true">02</div>
            <h3>See the full picture</h3>
            <p>Your combined revenue from every source, broken down by platform, time period, and trends. Updated automatically.</p>
        </div>
        <div class="step" aria-label="Step 3: Set goals and grow">
            <div class="step-num" aria-hidden="true">03</div>
            <h3>Set goals and grow</h3>
            <p>Track your monthly targets, spot your best-performing platforms, and export clean data when tax season hits.</p>
        </div>
    </div>
</section>

<!-- FEATURES -->
<section class="features-section" id="features" aria-labelledby="features-heading">
    <div class="section-tag" aria-hidden="true">Features</div>
    <h2 id="features-heading">Built for people with multiple income streams</h2>
    <p>Whether you sell on two platforms or ten, MyTalli gives you one source of truth.</p>
    <div class="features-grid">
        <div class="feature-card">
            <div class="feature-icon" role="img" aria-label="Bar chart">📊</div>
            <h3>Real-time revenue tracking</h3>
            <p>See your total earnings update as sales come in across every connected platform.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon" role="img" aria-label="Chart with upward trend">📈</div>
            <h3>Trends &amp; comparisons</h3>
            <p>Month-over-month growth, platform breakdowns, and historical data so you know what's working.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon" role="img" aria-label="Bullseye target">🎯</div>
            <h3>Revenue goals</h3>
            <p>Set monthly income targets and track your progress with visual indicators that keep you motivated.</p>
        </div>
        <div class="feature-card">
            <div class="feature-icon" role="img" aria-label="Inbox tray">📥</div>
            <h3>CSV export</h3>
            <p>Download your revenue data in clean CSV format. Makes tax prep and bookkeeping painless.</p>
        </div>
    </div>
</section>

<!-- PRICING TEASER -->
<section class="pricing-section" id="pricing" aria-labelledby="pricing-heading">
    <div class="section-tag" aria-hidden="true">Pricing</div>
    <h2 id="pricing-heading">Start free. Upgrade when you're ready.</h2>
    <p>No tricks. A generous free tier that works, and a Pro plan for when you need more.</p>
    <div class="pricing-cards">
        <div class="price-card free">
            <h3>Free</h3>
            <div class="price">$0</div>
            <div class="price-sub">Forever free</div>
            <ul class="price-features">
                <li><span class="sr-only">Included: </span>1 connected platform</li>
                <li><span class="sr-only">Included: </span>Basic dashboard</li>
                <li><span class="sr-only">Included: </span>30-day history</li>
            </ul>
        </div>
        <div class="price-card pro">
            <h3>Pro</h3>
            <div class="price">$12<span style="font-size:16px;font-weight:400">/mo</span></div>
            <div class="price-sub">or $99/year (save 31%)</div>
            <ul class="price-features">
                <li><span class="sr-only">Included: </span>Unlimited platforms</li>
                <li><span class="sr-only">Included: </span>Full revenue history</li>
                <li><span class="sr-only">Included: </span>Goals &amp; weekly emails</li>
                <li><span class="sr-only">Included: </span>CSV export</li>
            </ul>
        </div>
    </div>
</section>

<!-- BOTTOM CTA -->
<section class="bottom-cta">
    <h2>Stop guessing. Start knowing.</h2>
    <p>Join the waitlist and be first in line when MyTalli launches.</p>
    <a class="waitlist-btn" href="/signin">Join Waitlist</a>
</section>

<!-- FOOTER -->
</main>
<footer role="contentinfo">
    <p>&copy; 2026 MyTalli. All rights reserved.</p>
    <a href="mailto:hello@mytalli.com">hello@mytalli.com</a>
</footer>
