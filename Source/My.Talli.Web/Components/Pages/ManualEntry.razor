@page "/manual-entry"
@inherits My.Talli.Web.ViewModels.Pages.ManualEntryViewModel
@rendermode InteractiveServer

<PageTitle>@PageTitle — MyTalli</PageTitle>

<!-- Swoosh hero -->
<section class="hero manual-hero" aria-label="Manual entry overview">
    <div class="hero-bg" aria-hidden="true">
        <svg preserveAspectRatio="none" viewBox="0 0 1000 600" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="manualSwooshGrad" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#6c5ce7" />
                    <stop offset="50%" stop-color="#8b5cf6" />
                    <stop offset="100%" stop-color="#6c5ce7" />
                </linearGradient>
            </defs>
            <path d="M0,0 L1000,0 L1000,320 C850,400 650,280 450,340 C250,400 100,360 0,300 Z" fill="url(#manualSwooshGrad)" />
        </svg>
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>
        <div class="deco-circle deco-circle-3"></div>
    </div>

    <div class="hero-content">
        <div class="hero-top manual-hero-top">
            <div>
                <h1>Manual Entry</h1>
                <p class="hero-subtitle">Record revenue from any source</p>
            </div>
            <ul class="hero-nav">
                <li><My.Talli.Web.Components.Shared.UserProfileButton @rendermode="InteractiveServer" /></li>
            </ul>
        </div>

        @if (Entries.Count > 0)
        {
            <div class="hero-stats manual-stats" role="group" aria-label="Entry statistics">
                <div class="hero-stat">
                    <span class="hero-stat-num">@TotalEntries</span>
                    <span class="hero-stat-label">Entries</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-num">@TotalGross.ToString("C2")</span>
                    <span class="hero-stat-label">Gross</span>
                </div>
                <div class="hero-stat">
                    <span class="hero-stat-num">@TotalNet.ToString("C2")</span>
                    <span class="hero-stat-label">Net</span>
                </div>
            </div>
        }
    </div>
</section>

@* Shop picker bar *@
@if (HasModuleAccess)
{
    <div class="shop-bar">
        <div class="shop-bar-left">
            <span class="shop-bar-label">Shop</span>
            @if (IsAddingShop)
            {
                <div class="shop-add-form" role="group" aria-label="Create new shop">
                    <input class="shop-add-input" type="text" placeholder="Shop name…" maxlength="255" @bind="NewShopName" @bind:event="oninput" @onkeydown="HandleAddShopKeyDownAsync" @ref="NewShopNameRef" aria-label="New shop name" />
                    <button class="shop-add-ok" @onclick="ConfirmAddShopAsync" disabled="@string.IsNullOrWhiteSpace(NewShopName)" aria-label="Create shop" title="Create">
                        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                    </button>
                    <button class="shop-add-cancel" @onclick="CancelAddShop" aria-label="Cancel" title="Cancel">
                        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3" viewBox="0 0 24 24"><line x1="18" x2="6" y1="6" y2="18" /><line x1="6" x2="18" y1="6" y2="18" /></svg>
                    </button>
                </div>
            }
            else
            {
                <div class="shop-picker-wrap">
                    <button class="shop-picker @(IsShopDropdownOpen ? "open" : "")" @onclick="ToggleShopDropdown" aria-haspopup="listbox" aria-expanded="@IsShopDropdownOpen">
                        <span class="shop-picker-icon" aria-hidden="true">
                            <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l1-5h16l1 5M5 9v11a1 1 0 0 0 1 1h12a1 1 0 0 0 1-1V9M9 21v-6h6v6" /></svg>
                        </span>
                        <span class="shop-picker-name">@ActiveShopName</span>
                        <span class="shop-picker-caret" aria-hidden="true">
                            @if (IsShopDropdownOpen)
                            {
                                <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="18 15 12 9 6 15" /></svg>
                            }
                            else
                            {
                                <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="6 9 12 15 18 9" /></svg>
                            }
                        </span>
                    </button>
                    @if (IsShopDropdownOpen)
                    {
                        <div class="shop-dropdown" role="listbox" aria-label="Manual shops">
                            @foreach (var shop in Shops)
                            {
                                @if (shop.Id == EditingShopId)
                                {
                                    <div class="shop-dropdown-edit" role="group" aria-label="Rename shop">
                                        <input class="shop-dropdown-edit-input" type="text" maxlength="255" @bind="EditShopName" @bind:event="oninput" @onkeydown="HandleEditShopKeyDownAsync" @ref="EditShopNameRef" aria-label="Shop name" />
                                        <button class="shop-dropdown-edit-ok" @onclick="ConfirmEditShopAsync" disabled="@string.IsNullOrWhiteSpace(EditShopName)" aria-label="Save name" title="Save">
                                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                        </button>
                                        <button class="shop-dropdown-edit-cancel" @onclick="CancelEditShop" aria-label="Cancel" title="Cancel">
                                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3" viewBox="0 0 24 24"><line x1="18" x2="6" y1="6" y2="18" /><line x1="6" x2="18" y1="6" y2="18" /></svg>
                                        </button>
                                    </div>
                                }
                                else
                                {
                                    <div class="shop-dropdown-row @(shop.Id == ActiveShopConnectionId ? "active" : "")">
                                        <button class="shop-dropdown-item" role="option" aria-selected="@(shop.Id == ActiveShopConnectionId)" @onclick="() => SelectShopAsync(shop.Id)">
                                            <span>@shop.ShopName</span>
                                            @if (shop.Id == ActiveShopConnectionId)
                                            {
                                                <span class="check" aria-hidden="true">
                                                    <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                                </span>
                                            }
                                        </button>
                                        <button class="shop-dropdown-edit-btn" @onclick="() => StartEditShopAsync(shop.Id)" aria-label="Rename @shop.ShopName" title="Rename">
                                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                        </button>
                                    </div>
                                }
                            }
                            <div class="shop-dropdown-divider"></div>
                            <button class="shop-dropdown-item shop-dropdown-add" @onclick="StartAddShopAsync">
                                <span class="plus" aria-hidden="true">
                                    <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="3" viewBox="0 0 24 24"><line x1="12" x2="12" y1="5" y2="19" /><line x1="5" x2="19" y1="12" y2="12" /></svg>
                                </span>
                                Add new shop…
                            </button>
                        </div>
                    }
                </div>
            }
        </div>
        @if (IsAddingShop)
        {
            <span class="shop-bar-hint">Press <strong>Enter</strong> to create</span>
        }
        else
        {
            <span class="shop-bar-hint">New entries save to <strong>@ActiveShopName</strong></span>
        }
    </div>
    @if (IsShopDropdownOpen)
    {
        <div class="shop-dropdown-backdrop" @onclick="CloseShopDropdown" aria-hidden="true"></div>
    }
}

<!-- Spoke tabs -->
<nav class="spoke-tabs" role="tablist" aria-label="Manual entry sections">
    <button class="spoke-tab @(ActiveTab == "overview" ? "active" : "")" role="tab" aria-selected="@(ActiveTab == "overview")" @onclick='() => SelectTab("overview")'>Overview</button>
    <button class="spoke-tab @(ActiveTab == "revenue" ? "active" : "")" role="tab" aria-selected="@(ActiveTab == "revenue")" @onclick='() => SelectTab("revenue")'>Revenue</button>
    <button class="spoke-tab @(ActiveTab == "expenses" ? "active" : "")" role="tab" aria-selected="@(ActiveTab == "expenses")" @onclick='() => SelectTab("expenses")'>Expenses</button>
    <button class="spoke-tab @(ActiveTab == "payouts" ? "active" : "")" role="tab" aria-selected="@(ActiveTab == "payouts")" @onclick='() => SelectTab("payouts")'>Payouts</button>
</nav>

@if (IsSampleData)
{
    <!-- Sample data banner -->
    <div class="manual-sample-banner animate-in delay-2" role="status">
        <div class="manual-sample-left">
            <div class="manual-sample-icon" aria-hidden="true">
                <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" /><line x1="12" x2="12" y1="8" y2="12" /><line x1="12" x2="12.01" y1="16" y2="16" /></svg>
            </div>
            <p>You're viewing <strong>sample data</strong>. Get Manual Entry to start tracking your own revenue.</p>
        </div>
        <a class="manual-sample-btn" href="/my-plan">Get Manual Entry — $3/mo</a>
    </div>
}

@* ── OVERVIEW TAB ── *@
@if (ActiveTab == "overview")
{
    <div class="manual-overview animate-in delay-2" role="tabpanel" aria-label="Overview">
        <div class="overview-cards">
            <div class="overview-card">
                <div class="overview-card-label">Total Revenue</div>
                <div class="overview-card-value revenue">@TotalGross.ToString("C0")</div>
                <div class="overview-card-sub">@TotalEntries entries</div>
            </div>
            <div class="overview-card">
                <div class="overview-card-label">Total Expenses</div>
                <div class="overview-card-value expense">@TotalExpenses.ToString("C0")</div>
                <div class="overview-card-sub">@Expenses.Count items</div>
            </div>
            <div class="overview-card">
                <div class="overview-card-label">Net Profit</div>
                <div class="overview-card-value @(TotalNetProfit >= 0 ? "revenue" : "expense")">@TotalNetProfit.ToString("C0")</div>
                <div class="overview-card-sub">revenue minus expenses</div>
            </div>
            <div class="overview-card">
                <div class="overview-card-label">Total Payouts</div>
                <div class="overview-card-value payout">@TotalPayouts.ToString("C0")</div>
                <div class="overview-card-sub">@Payouts.Count disbursements</div>
            </div>
        </div>

        <!-- Top categories breakdown -->
        <div class="overview-section-card">
            <h3>Revenue by Category</h3>
            @foreach (var group in Entries.GroupBy(e => e.Category).OrderByDescending(g => g.Sum(e => e.GrossAmount)).Take(5))
            {
                var pct = TotalGross > 0 ? (int)(group.Sum(e => e.GrossAmount) / TotalGross * 100) : 0;
                <div class="overview-bar-row">
                    <span class="manual-cat-tag @group.First().CategoryCss">@group.Key</span>
                    <div class="overview-bar-track">
                        <div class="overview-bar-fill" style="width:@(pct)%"></div>
                    </div>
                    <span class="overview-bar-amount">@group.Sum(e => e.GrossAmount).ToString("C0")</span>
                    <span class="overview-bar-pct">@(pct)%</span>
                </div>
            }
        </div>

        <!-- Recent activity -->
        <div class="overview-section-card">
            <h3>Recent Activity</h3>
            <table class="overview-activity-table">
                <thead>
                    <tr><th>Date</th><th>Description</th><th>Type</th><th class="overview-th-right">Amount</th></tr>
                </thead>
                <tbody>
                    @foreach (var entry in Entries.OrderByDescending(e => e.TransactionDate).Take(5))
                    {
                        <tr>
                            <td class="overview-td-date">@entry.TransactionDateLabel</td>
                            <td>@entry.Description</td>
                            <td><span class="manual-cat-tag @entry.CategoryCss">@entry.Category</span></td>
                            <td class="overview-td-amount revenue">@entry.NetAmount.ToString("C2")</td>
                        </tr>
                    }
                    @foreach (var expense in Expenses.OrderByDescending(e => e.ExpenseDate).Take(3))
                    {
                        <tr>
                            <td class="overview-td-date">@expense.ExpenseDateLabel</td>
                            <td>@expense.Description</td>
                            <td><span class="manual-cat-tag @expense.CategoryCss">@expense.Category</span></td>
                            <td class="overview-td-amount expense">-@expense.Amount.ToString("C2")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@* ── REVENUE TAB ── *@
@if (ActiveTab == "revenue")
{
    <!-- Entry grid -->
    <div class="manual-table-wrap animate-in delay-2" role="tabpanel" aria-label="Revenue">
        <div class="manual-table-scroll">
            <table class="manual-table @DensityCss" aria-label="Manual revenue entries">
                <thead>
                    <tr>
                        <th class="manual-th-sort" @onclick='() => SortBy("TransactionDate")'>Date <span class="manual-sort-ind" aria-hidden="true">@GetSortIndicator("TransactionDate")</span></th>
                        <th class="manual-th-sort" @onclick='() => SortBy("Description")'>Description <span class="manual-sort-ind" aria-hidden="true">@GetSortIndicator("Description")</span></th>
                        <th class="manual-th-sort" @onclick='() => SortBy("Category")'>Category <span class="manual-sort-ind" aria-hidden="true">@GetSortIndicator("Category")</span></th>
                        <th class="manual-th-sort manual-th-right" @onclick='() => SortBy("Quantity")'>Qty <span class="manual-sort-ind" aria-hidden="true">@GetSortIndicator("Quantity")</span></th>
                        <th class="manual-th-sort manual-th-right" @onclick='() => SortBy("UnitPrice")'>Price <span class="manual-sort-ind" aria-hidden="true">@GetSortIndicator("UnitPrice")</span></th>
                        <th class="manual-th-sort manual-th-right" @onclick='() => SortBy("FeeAmount")'>Fees <span class="manual-sort-ind" aria-hidden="true">@GetSortIndicator("FeeAmount")</span></th>
                        <th class="manual-th-sort manual-th-right" @onclick='() => SortBy("NetAmount")'>Net <span class="manual-sort-ind" aria-hidden="true">@GetSortIndicator("NetAmount")</span></th>
                        @if (!IsSampleData)
                        {
                            <th class="manual-th-actions"></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @* Quick-entry row *@
                    @if (HasModuleAccess)
                    {
                        <tr class="qe-row" @onkeydown="HandleQuickEntryKeyDown" aria-label="Add new entry">
                            <td><input class="qe-input qe-date" type="date" @bind="NewTransactionDate" /></td>
                            <td><input class="qe-input qe-desc" type="text" placeholder="Description..." @bind="NewDescription" @ref="QuickEntryDescriptionRef" /></td>
                            <td>
                                <select class="qe-select" @bind="NewCategory">
                                    @foreach (var cat in Categories)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                </select>
                            </td>
                            <td><input class="qe-input qe-num" type="number" step="1" min="1" @bind="NewQuantity" /></td>
                            <td><input class="qe-input qe-num" type="number" step="0.01" min="0" placeholder="0.00" @bind="NewUnitPrice" /></td>
                            <td><input class="qe-input qe-num" type="number" step="0.01" min="0" placeholder="0.00" @bind="NewFeeAmount" /></td>
                            <td class="qe-net">@((NewUnitPrice * NewQuantity - NewFeeAmount).ToString("C2"))</td>
                            <td>
                                <button class="qe-add-btn" @onclick="QuickAddAsync" disabled="@(string.IsNullOrWhiteSpace(NewDescription) || NewUnitPrice <= 0)" aria-label="Add entry">
                                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" x2="12" y1="5" y2="19" /><line x1="5" x2="19" y1="12" y2="12" /></svg>
                                </button>
                            </td>
                        </tr>
                    }
                    @foreach (var entry in PagedEntries)
                    {
                        @if (entry.Id == EditingId)
                        {
                            @* Inline edit row *@
                            <tr class="inline-edit-row" @onkeydown="HandleEditKeyDown" aria-label="Editing entry">
                                <td><input class="qe-input qe-date" type="date" @bind="EditTransactionDate" /></td>
                                <td><input class="qe-input qe-desc" type="text" @bind="EditDescription" /></td>
                                <td>
                                    <select class="qe-select" @bind="EditCategory">
                                        @foreach (var cat in Categories)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </select>
                                </td>
                                <td><input class="qe-input qe-num" type="number" step="1" min="1" @bind="EditQuantity" /></td>
                                <td><input class="qe-input qe-num" type="number" step="0.01" min="0" @bind="EditUnitPrice" /></td>
                                <td><input class="qe-input qe-num" type="number" step="0.01" min="0" @bind="EditFeeAmount" /></td>
                                <td class="qe-net">@((EditUnitPrice * EditQuantity - EditFeeAmount).ToString("C2"))</td>
                                <td class="manual-td-actions">
                                    <button class="qe-notes-toggle @(ShowEditNotes ? "active" : "")" @onclick="ToggleEditNotes" aria-label="Toggle notes" title="Notes">
                                        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" /></svg>
                                    </button>
                                    <button class="qe-save-btn" @onclick="SaveEditAsync" aria-label="Save changes" title="Save">
                                        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                    </button>
                                    <button class="qe-cancel-btn" @onclick="CancelEdit" aria-label="Cancel editing" title="Cancel">
                                        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" x2="6" y1="6" y2="18" /><line x1="6" x2="18" y1="6" y2="18" /></svg>
                                    </button>
                                </td>
                            </tr>
                            @if (ShowEditNotes)
                            {
                                <tr class="qe-notes-row">
                                    <td colspan="8">
                                        <div class="qe-notes-wrap">
                                            <label class="qe-notes-label">Notes</label>
                                            <input class="qe-input qe-notes-input" type="text" placeholder="Any extra details..." @bind="EditNotes" @onkeydown="HandleEditKeyDown" />
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            @* Display row *@
                            <tr>
                                <td class="manual-td-date">@entry.TransactionDateLabel</td>
                                <td class="manual-td-desc">
                                    @entry.Description
                                    @if (!string.IsNullOrWhiteSpace(entry.Notes))
                                    {
                                        <span class="manual-notes-icon" data-notes="@entry.Notes" aria-label="Notes: @entry.Notes">
                                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                            </svg>
                                        </span>
                                    }
                                </td>
                                <td><span class="manual-cat-tag @entry.CategoryCss">@entry.Category</span></td>
                                <td class="manual-td-money">@entry.Quantity</td>
                                <td class="manual-td-money">@entry.UnitPrice.ToString("C2")</td>
                                <td class="manual-td-money fee">@(entry.FeeAmount > 0 ? $"-{entry.FeeAmount:C2}" : "\u2014")</td>
                                <td class="manual-td-money net">@entry.NetAmount.ToString("C2")</td>
                                @if (!IsSampleData)
                                {
                                    <td class="manual-td-actions">
                                        <button class="manual-action-btn" aria-label="Edit @entry.Description" disabled="@(EditingId.HasValue)" @onclick="() => StartEdit(entry.Id)">
                                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                        </button>
                                        <button class="manual-action-btn danger" aria-label="Delete @entry.Description" disabled="@(EditingId.HasValue)" @onclick="() => DeleteEntry(entry.Id)">
                                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                            </svg>
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    @if (!IsSampleData && Entries.Count == 0)
                    {
                        <tr>
                            <td class="manual-td-empty" colspan="8">
                                <div class="manual-empty-row">
                                    <svg aria-hidden="true" fill="none" height="36" stroke="#a78bfa" stroke-linecap="round" stroke-width="1.5" viewBox="0 0 24 24" width="36">
                                        <path d="M12 5v14M5 12h14" />
                                    </svg>
                                    <h3>No entries yet</h3>
                                    <p>Type your first entry in the row above to start tracking your revenue.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Entries.Count > 0)
        {
        <div class="manual-pagination">
            <div class="manual-page-size">
                <label for="manual-page-select">Show</label>
                <select class="manual-page-select" id="manual-page-select" @bind="PageSize" @bind:after="ChangePageSize">
                    @foreach (var size in PageSizeOptions)
                    {
                        <option value="@size">@size</option>
                    }
                </select>
                <span>entries</span>
            </div>
            <div class="manual-density" role="group" aria-label="Row density">
                <button class="manual-density-btn @(Density == "compact" ? "active" : "")" aria-pressed="@(Density == "compact")" title="Compact" @onclick='() => SetDensity("compact")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="6" y2="6" /><line x1="2" x2="14" y1="9" y2="9" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
                <button class="manual-density-btn @(Density == "comfortable" ? "active" : "")" aria-pressed="@(Density == "comfortable")" title="Comfortable" @onclick='() => SetDensity("comfortable")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="8" y2="8" /><line x1="2" x2="14" y1="13" y2="13" /></svg>
                </button>
                <button class="manual-density-btn @(Density == "spacious" ? "active" : "")" aria-pressed="@(Density == "spacious")" title="Spacious" @onclick='() => SetDensity("spacious")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="4" y2="4" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
            </div>
            <span class="manual-page-info">@((CurrentPage - 1) * PageSize + 1)–@Math.Min(CurrentPage * PageSize, TotalEntries) of @TotalEntries</span>
            <div class="manual-page-nav" role="group" aria-label="Pagination">
                <button class="manual-page-btn" disabled="@(CurrentPage <= 1)" @onclick="() => GoToPage(CurrentPage - 1)" aria-label="Previous page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <button class="manual-page-btn" disabled="@(CurrentPage >= TotalPages)" @onclick="() => GoToPage(CurrentPage + 1)" aria-label="Next page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                </button>
            </div>
        </div>
        }
    </div>
}

@* ── EXPENSES TAB ── *@
@if (ActiveTab == "expenses")
{
    <div class="manual-table-wrap animate-in delay-2" role="tabpanel" aria-label="Expenses">
        <div class="manual-table-scroll">
            <table class="manual-table @DensityCss" aria-label="Manual expenses">
                <thead>
                    <tr>
                        <th class="manual-th-sort" @onclick='() => SortExpensesBy("ExpenseDate")'>Date <span class="manual-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("ExpenseDate")</span></th>
                        <th class="manual-th-sort" @onclick='() => SortExpensesBy("Description")'>Description <span class="manual-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("Description")</span></th>
                        <th class="manual-th-sort" @onclick='() => SortExpensesBy("Category")'>Category <span class="manual-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("Category")</span></th>
                        <th class="manual-th-sort manual-th-right" @onclick='() => SortExpensesBy("Amount")'>Amount <span class="manual-sort-ind" aria-hidden="true">@GetExpenseSortIndicator("Amount")</span></th>
                        @if (!IsSampleData)
                        {
                            <th class="manual-th-actions"></th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @* Quick-entry row *@
                    @if (HasModuleAccess)
                    {
                        <tr class="qe-row" @onkeydown="HandleExpenseQuickEntryKeyDown" aria-label="Add new expense">
                            <td><input class="qe-input qe-date" type="date" @bind="NewExpenseDate" /></td>
                            <td><input class="qe-input qe-desc" type="text" placeholder="Description..." @bind="NewExpenseDescription" @ref="ExpenseQuickEntryDescriptionRef" /></td>
                            <td>
                                <select class="qe-select" @bind="NewExpenseCategory">
                                    @foreach (var cat in ExpenseCategories)
                                    {
                                        <option value="@cat">@cat</option>
                                    }
                                </select>
                            </td>
                            <td><input class="qe-input qe-num" type="number" step="0.01" min="0" placeholder="0.00" @bind="NewExpenseAmount" /></td>
                            <td>
                                <button class="qe-add-btn" @onclick="QuickAddExpenseAsync" disabled="@(string.IsNullOrWhiteSpace(NewExpenseDescription) || NewExpenseAmount <= 0)" aria-label="Add expense">
                                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" viewBox="0 0 24 24"><line x1="12" x2="12" y1="5" y2="19" /><line x1="5" x2="19" y1="12" y2="12" /></svg>
                                </button>
                            </td>
                        </tr>
                    }
                    @foreach (var expense in PagedExpenses)
                    {
                        @if (expense.Id == ExpenseEditingId)
                        {
                            @* Inline edit row *@
                            <tr class="inline-edit-row" @onkeydown="HandleExpenseEditKeyDown" aria-label="Editing expense">
                                <td><input class="qe-input qe-date" type="date" @bind="EditExpenseDate" /></td>
                                <td><input class="qe-input qe-desc" type="text" @bind="EditExpenseDescription" /></td>
                                <td>
                                    <select class="qe-select" @bind="EditExpenseCategory">
                                        @foreach (var cat in ExpenseCategories)
                                        {
                                            <option value="@cat">@cat</option>
                                        }
                                    </select>
                                </td>
                                <td><input class="qe-input qe-num" type="number" step="0.01" min="0" @bind="EditExpenseAmount" /></td>
                                <td class="manual-td-actions">
                                    <button class="qe-save-btn" @onclick="SaveEditExpenseAsync" aria-label="Save changes" title="Save">
                                        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" viewBox="0 0 24 24"><polyline points="20 6 9 17 4 12" /></svg>
                                    </button>
                                    <button class="qe-cancel-btn" @onclick="CancelEditExpense" aria-label="Cancel editing" title="Cancel">
                                        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2.5" viewBox="0 0 24 24"><line x1="18" x2="6" y1="6" y2="18" /><line x1="6" x2="18" y1="6" y2="18" /></svg>
                                    </button>
                                </td>
                            </tr>
                        }
                        else
                        {
                            @* Display row *@
                            <tr>
                                <td class="manual-td-date">@expense.ExpenseDateLabel</td>
                                <td class="manual-td-desc">@expense.Description</td>
                                <td><span class="manual-cat-tag @expense.CategoryCss">@expense.Category</span></td>
                                <td class="manual-td-money fee">-@expense.Amount.ToString("C2")</td>
                                @if (!IsSampleData)
                                {
                                    <td class="manual-td-actions">
                                        <button class="manual-action-btn" aria-label="Edit @expense.Description" disabled="@(ExpenseEditingId.HasValue)" @onclick="() => StartEditExpense(expense.Id)">
                                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24">
                                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                            </svg>
                                        </button>
                                        <button class="manual-action-btn danger" aria-label="Delete @expense.Description" disabled="@(ExpenseEditingId.HasValue)" @onclick="() => DeleteExpense(expense.Id)">
                                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24">
                                                <polyline points="3 6 5 6 21 6" />
                                                <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2" />
                                            </svg>
                                        </button>
                                    </td>
                                }
                            </tr>
                        }
                    }
                    @if (!IsSampleData && Expenses.Count == 0)
                    {
                        <tr>
                            <td class="manual-td-empty" colspan="5">
                                <div class="manual-empty-row">
                                    <svg aria-hidden="true" fill="none" height="36" stroke="#a78bfa" stroke-linecap="round" stroke-width="1.5" viewBox="0 0 24 24" width="36">
                                        <path d="M12 5v14M5 12h14" />
                                    </svg>
                                    <h3>No expenses yet</h3>
                                    <p>Type your first expense in the row above to start tracking your costs.</p>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        @if (Expenses.Count > 0)
        {
        <div class="manual-pagination">
            <div class="manual-page-size">
                <label for="expense-page-select">Show</label>
                <select class="manual-page-select" id="expense-page-select" @bind="PageSize" @bind:after="ChangePageSize">
                    @foreach (var size in PageSizeOptions)
                    {
                        <option value="@size">@size</option>
                    }
                </select>
                <span>entries</span>
            </div>
            <div class="manual-density" role="group" aria-label="Row density">
                <button class="manual-density-btn @(Density == "compact" ? "active" : "")" aria-pressed="@(Density == "compact")" title="Compact" @onclick='() => SetDensity("compact")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="6" y2="6" /><line x1="2" x2="14" y1="9" y2="9" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
                <button class="manual-density-btn @(Density == "comfortable" ? "active" : "")" aria-pressed="@(Density == "comfortable")" title="Comfortable" @onclick='() => SetDensity("comfortable")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="3" y2="3" /><line x1="2" x2="14" y1="8" y2="8" /><line x1="2" x2="14" y1="13" y2="13" /></svg>
                </button>
                <button class="manual-density-btn @(Density == "spacious" ? "active" : "")" aria-pressed="@(Density == "spacious")" title="Spacious" @onclick='() => SetDensity("spacious")'>
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 16 16"><line x1="2" x2="14" y1="4" y2="4" /><line x1="2" x2="14" y1="12" y2="12" /></svg>
                </button>
            </div>
            <span class="manual-page-info">@((ExpenseCurrentPage - 1) * PageSize + 1)–@Math.Min(ExpenseCurrentPage * PageSize, Expenses.Count) of @Expenses.Count</span>
            <div class="manual-page-nav" role="group" aria-label="Pagination">
                <button class="manual-page-btn" disabled="@(ExpenseCurrentPage <= 1)" @onclick="() => GoToExpensePage(ExpenseCurrentPage - 1)" aria-label="Previous page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6" /></svg>
                </button>
                <button class="manual-page-btn" disabled="@(ExpenseCurrentPage >= TotalExpensePages)" @onclick="() => GoToExpensePage(ExpenseCurrentPage + 1)" aria-label="Next page">
                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" /></svg>
                </button>
            </div>
        </div>
        }
    </div>
}

