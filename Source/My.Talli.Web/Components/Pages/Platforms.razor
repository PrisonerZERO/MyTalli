@page "/platforms"
@inherits My.Talli.Web.ViewModels.Pages.PlatformsViewModel
@rendermode InteractiveServer

<PageTitle>Platforms — MyTalli</PageTitle>

<!-- Swoosh hero -->
<section class="hero plat-hero" aria-label="Platform status overview">
    <div class="hero-bg" aria-hidden="true">
        <svg preserveAspectRatio="none" viewBox="0 0 1000 600" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="platSwooshGrad" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#6c5ce7" />
                    <stop offset="50%" stop-color="#8b5cf6" />
                    <stop offset="100%" stop-color="#6c5ce7" />
                </linearGradient>
            </defs>
            <path d="M0,0 L1000,0 L1000,320 C850,400 650,280 450,340 C250,400 100,360 0,300 Z" fill="url(#platSwooshGrad)" />
        </svg>
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>
        <div class="deco-circle deco-circle-3"></div>
    </div>

    <div class="hero-content">
        <div class="hero-top">
            <div>
                <h1>Platform Status</h1>
                <p class="hero-subtitle">Monitor your connections and sync health at a glance.</p>
            </div>
            <ul class="hero-nav">
                <li><My.Talli.Web.Components.Shared.UserProfileButton @rendermode="InteractiveServer" /></li>
            </ul>
        </div>

        <div class="hero-stats" role="group" aria-label="Platform statistics">
            <div class="hero-stat">
                <span class="hero-stat-num">@ConnectedCount</span>
                <span class="hero-stat-label">Connected</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-num">@AvailableCount</span>
                <span class="hero-stat-label">Available</span>
            </div>
            <div class="hero-stat">
                <span class="hero-stat-num">@TotalTransactions</span>
                <span class="hero-stat-label">Transactions Synced</span>
            </div>
        </div>
    </div>
</section>

@if (!string.IsNullOrEmpty(SuccessMessage))
{
    <div class="plat-toast plat-toast-success animate-in delay-1" role="status">
        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24">
            <path d="M22 11.08V12a10 10 0 11-5.93-9.14" />
            <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
        <span>@SuccessMessage</span>
        <button class="plat-toast-dismiss" aria-label="Dismiss notification" @onclick="DismissMessage">&times;</button>
    </div>
}
@if (!string.IsNullOrEmpty(ErrorMessage))
{
    <div class="plat-toast plat-toast-error animate-in delay-1" role="alert">
        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" x2="12" y1="8" y2="12" />
            <line x1="12" x2="12.01" y1="16" y2="16" />
        </svg>
        <span>@ErrorMessage</span>
        <button class="plat-toast-dismiss" aria-label="Dismiss notification" @onclick="DismissMessage">&times;</button>
    </div>
}

@if (IsLoading)
{
    <section class="plat-loading-card animate-in delay-1" aria-label="Loading platforms">
        <div class="plat-loading" role="status">
            <p>Loading your platforms...</p>
        </div>
    </section>
}
else
{
    <!-- Connected platforms -->
    <div class="animate-in delay-2">
        <div class="plat-section-header">
            <h2>Connected</h2>
            <span class="plat-section-count">@ConnectedCount</span>
        </div>

        @if (ConnectedPlatforms.Any())
        {
            @foreach (var platform in ConnectedPlatforms)
            {
                <article class="plat-row plat-row-platform" aria-label="@platform.Name platform, connected">
                    <div class="plat-row-header">
                        <div class="plat-row-identity">
                            <div class="plat-icon" style="background: @platform.BrandColor;" aria-hidden="true">
                                @RenderPlatformIcon(platform.Icon)
                            </div>
                            <div>
                                <div class="plat-row-name">@platform.Name</div>
                                <div class="plat-row-sub">@platform.Description</div>
                            </div>
                        </div>
                        <div class="plat-row-header-meta">
                            <div class="plat-row-status">
                                <span class="plat-status-dot @StatusDotClass(platform.ConnectionStatus)" aria-hidden="true"></span>
                                <span class="plat-status-text">@StatusLabel(platform.ConnectionStatus)</span>
                            </div>
                            <div class="plat-row-data">@platform.Shops.Count @(platform.Shops.Count == 1 ? "shop" : "shops") • @platform.TransactionCount transactions</div>
                            @if (platform.Name == "Etsy")
                            {
                                <a class="plat-btn-view" href="/platforms/etsy" aria-label="View Etsy dashboard — revenue, expenses, and payouts">View dashboard →</a>
                            }
                        </div>
                    </div>

                    <ul class="plat-shop-list" aria-label="Connected @platform.Name shops">
                        @foreach (var shop in platform.Shops)
                        {
                            <li class="plat-shop-row" aria-label="@shop.ShopName shop">
                                <div class="plat-shop-identity">
                                    <svg aria-hidden="true" class="plat-shop-icon" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                                        <path d="M3 9l1-5h16l1 5" />
                                        <path d="M5 9v11a1 1 0 001 1h12a1 1 0 001-1V9" />
                                        <path d="M9 13h6" />
                                    </svg>
                                    <span class="plat-shop-name">@shop.ShopName</span>
                                </div>
                                <div class="plat-shop-meta">
                                    <span class="plat-shop-sync">
                                        @(shop.IsEnabled ? (string.IsNullOrEmpty(shop.LastSyncLabel) ? "Never synced" : shop.LastSyncLabel) : "Sync paused")
                                        @if (shop.IsEnabled && shop.SyncStatus == "Failed")
                                        {
                                            <span class="plat-sync-error" title="@shop.LastErrorMessage" aria-label="Sync error: @shop.LastErrorMessage">!</span>
                                        }
                                    </span>
                                    <span class="plat-shop-data">@shop.TransactionCount transactions</span>
                                </div>
                                <div class="plat-shop-actions">
                                    <button class="plat-btn-outline" aria-label="@(shop.IsEnabled ? $"Pause syncing for {shop.ShopName}" : $"Resume syncing for {shop.ShopName}")" @onclick="() => TogglePauseAsync(shop.ShopConnectionId)">
                                        @(shop.IsEnabled ? "Pause" : "Resume")
                                    </button>
                                </div>
                            </li>
                        }
                    </ul>

                    @if (platform.SupportsMultipleShops)
                    {
                        <div class="plat-shop-add">
                            @if (platform.CanAddAnotherShop)
                            {
                                <button class="plat-btn-add-shop" aria-label="Connect another @platform.Name shop" @onclick="() => StartConnectAnotherShop(platform.Name)">
                                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                                        <line x1="12" x2="12" y1="5" y2="19" />
                                        <line x1="5" x2="19" y1="12" y2="12" />
                                    </svg>
                                    Connect another shop
                                </button>
                            }
                            else
                            {
                                <a class="plat-btn-upgrade" href="/my-plan" aria-label="Upgrade to Pro to connect additional @platform.Name shops">
                                    <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" viewBox="0 0 24 24">
                                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
                                    </svg>
                                    <span>Upgrade to Pro to connect another @platform.Name shop</span>
                                </a>
                            }
                        </div>
                    }
                </article>
            }
        }
        else
        {
            <div class="plat-empty" role="status">
                <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24" class="plat-empty-icon">
                    <path d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m9.86-2.054a4.5 4.5 0 00-6.364-6.364L4.5 8.25" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <p>No platforms connected yet.</p>
                <p class="plat-empty-hint">Connect a platform below to start syncing your revenue data.</p>
            </div>
        }
    </div>

    <!-- Divider -->
    @if (AvailablePlatforms.Any())
    {
        <hr class="plat-divider" aria-hidden="true" />
    }

    <!-- Available platforms -->
    @if (AvailablePlatforms.Any())
    {
        <div class="animate-in delay-3">
            <div class="plat-section-header">
                <h2>Available</h2>
                <span class="plat-section-count">@AvailableCount</span>
            </div>

            @foreach (var platform in AvailablePlatforms)
            {
                <article class="plat-row plat-row-available" aria-label="@platform.Name platform, not connected">
                    <div class="plat-row-identity">
                        <div class="plat-icon" style="background: @platform.BrandColor;" aria-hidden="true">
                            @RenderPlatformIcon(platform.Icon)
                        </div>
                        <div>
                            <div class="plat-row-name">@platform.Name</div>
                            <div class="plat-row-sub">@platform.Description</div>
                        </div>
                    </div>
                    <div class="plat-row-actions">
                        <span class="plat-row-type">@platform.Subtitle</span>
                        <button class="plat-btn-connect" aria-label="Connect @platform.Name" @onclick="() => StartConnect(platform.Name)" disabled="@(platform.Name != "Etsy")">Connect</button>
                    </div>
                </article>
            }
        </div>
    }
}

<!-- Connect confirmation -->
<ConfirmDialog Visible="!string.IsNullOrEmpty(ConnectingPlatform)" ConfirmStyle="primary" OnConfirm="ConfirmConnect" OnCancel="CancelConnect">
    <svg aria-hidden="true" fill="none" height="40" stroke="#6c5ce7" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="40">
        <path d="M12 2a10 10 0 100 20 10 10 0 000-20z" />
        <line x1="12" x2="12" y1="8" y2="12" />
        <line x1="12" x2="12.01" y1="16" y2="16" />
    </svg>
    <h2>Connect @ConnectingPlatform?</h2>
    <p>Once connected, <strong>@ConnectingPlatform</strong> can't be disconnected — it will permanently occupy a plan slot. You can pause syncing anytime from this page.</p>
</ConfirmDialog>

<!-- Add another Etsy shop (new login) confirmation -->
<ConfirmDialog Visible="!string.IsNullOrEmpty(AddingShopToPlatform)" ConfirmStyle="primary" OnConfirm="ConfirmAddShop" OnCancel="CancelAddShop">
    <svg aria-hidden="true" fill="none" height="40" stroke="#6c5ce7" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" width="40">
        <path d="M3 9l1-5h16l1 5" />
        <path d="M5 9v11a1 1 0 001 1h12a1 1 0 001-1V9" />
        <path d="M9 13h6" />
    </svg>
    <h2>Add another @AddingShopToPlatform shop?</h2>
    <p>On @AddingShopToPlatform, each login owns exactly one shop. Sign in with a <strong>different</strong> @AddingShopToPlatform account on the next screen to add that account's shop. Each new shop permanently occupies a plan slot.</p>
</ConfirmDialog>

@* Platform icon fragments *@
@{
    RenderFragment RenderPlatformIcon(string icon) => icon switch
    {
        "stripe" => @<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 4H3a2 2 0 00-2 2v12a2 2 0 002 2h18a2 2 0 002-2V6a2 2 0 00-2-2z"/><line x1="1" x2="23" y1="10" y2="10"/></svg>,
        "etsy" => @<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" x2="21" y1="6" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>,
        "gumroad" => @<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/><path d="M1 1h4l2.68 13.39a2 2 0 002 1.61h9.72a2 2 0 002-1.61L23 6H6"/></svg>,
        "paypal" => @<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><line x1="12" x2="12" y1="1" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>,
        "shopify" => @<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>,
        _ => @<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/></svg>,
    };

    string StatusDotClass(string status) => status.ToLowerInvariant() switch
    {
        "active" => "connected",
        "expired" => "expired",
        "revoked" => "revoked",
        _ => "connected",
    };

    string StatusLabel(string status) => status.ToLowerInvariant() switch
    {
        "active" => "Active",
        "expired" => "Expired",
        "revoked" => "Revoked",
        _ => "Active",
    };
}
