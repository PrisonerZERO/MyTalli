@page "/suggestions"
@inherits My.Talli.Web.ViewModels.Pages.SuggestionBoxViewModel
@rendermode InteractiveServer

<PageTitle>Suggestion Box — MyTalli</PageTitle>

<!-- Swoosh hero -->
<section class="hero suggest-hero" aria-label="Suggestion box overview">
    <div class="hero-bg" aria-hidden="true">
        <svg preserveAspectRatio="none" viewBox="0 0 1000 600" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="suggestSwooshGrad" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#6c5ce7" />
                    <stop offset="50%" stop-color="#8b5cf6" />
                    <stop offset="100%" stop-color="#6c5ce7" />
                </linearGradient>
            </defs>
            <path d="M0,0 L1000,0 L1000,320 C850,400 650,280 450,340 C250,400 100,360 0,300 Z" fill="url(#suggestSwooshGrad)" />
        </svg>
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>
        <div class="deco-circle deco-circle-3"></div>
    </div>

    <div class="hero-content">
        <div class="hero-top">
            <div>
                <h1>Suggestion Box</h1>
                <p class="hero-subtitle">Help shape the future of MyTalli</p>
            </div>
            <ul class="hero-nav">
                <li>
                    <button class="hero-action-btn" @onclick="OpenModal">
                        <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24">
                            <line x1="12" x2="12" y1="5" y2="19" />
                            <line x1="5" x2="19" y1="12" y2="12" />
                        </svg>
                        New Suggestion
                    </button>
                </li>
                <li><My.Talli.Web.Components.Shared.UserProfileButton @rendermode="InteractiveServer" /></li>
            </ul>
        </div>

        <div class="hero-stats suggest-stats" role="group" aria-label="Suggestion statistics">
            <div class="hero-stat suggest-stat">
                <span class="hero-stat-num">@TotalIdeas</span>
                <span class="hero-stat-label suggest-stat-label">Ideas</span>
            </div>
            <div class="hero-stat suggest-stat">
                <span class="hero-stat-num">@TotalVotes</span>
                <span class="hero-stat-label suggest-stat-label">Votes</span>
            </div>
            <div class="hero-stat suggest-stat">
                <span class="hero-stat-num">@YourSuggestions</span>
                <span class="hero-stat-label suggest-stat-label">Yours</span>
            </div>
        </div>
    </div>
</section>

<!-- Category filter pills -->
<div class="suggest-toolbar animate-in delay-2">
    <div class="suggest-cat-pills" role="group" aria-label="Filter by category">
        @foreach (var cat in Categories)
        {
            <button class="suggest-cat-pill @(cat == ActiveCategory ? "active" : "")"
                    aria-pressed="@(cat == ActiveCategory ? "true" : "false")"
                    @onclick="() => SelectCategory(cat)">
                @cat
            </button>
        }
    </div>
    <div class="suggest-sort" role="group" aria-label="Sort order">
        Sort by:
        <button class="suggest-sort-btn @(ActiveSort == "Top" ? "active" : "")"
                aria-pressed="@(ActiveSort == "Top" ? "true" : "false")"
                @onclick="@(() => SelectSort("Top"))">Top</button>
        <button class="suggest-sort-btn @(ActiveSort == "New" ? "active" : "")"
                aria-pressed="@(ActiveSort == "New" ? "true" : "false")"
                @onclick="@(() => SelectSort("New"))">New</button>
    </div>
</div>

<!-- Card grid -->
<div class="suggest-grid animate-in delay-3">
    @foreach (var item in FilteredSuggestions)
    {
        <article class="suggest-card @item.CardCss">
            <div class="suggest-card-header">
                <h3 class="suggest-card-title">@item.Title</h3>
                <div class="suggest-card-header-right">
                    @if (item.Status != "New")
                    {
                        <span class="suggest-status-tag @item.StatusCss">@item.StatusLabel</span>
                    }
                    <span class="suggest-card-date">@item.DateLabel</span>
                    <span class="suggest-cat-tag @item.CategoryCss">@item.Category</span>
                </div>
            </div>
            <div class="suggest-card-desc">@item.Description</div>

            @if (EditingNoteId == item.Id)
            {
                <!-- Admin note edit area -->
                <div class="suggest-note-edit" role="group" aria-label="Edit admin note">
                    <textarea class="suggest-note-textarea" aria-label="Admin note for @item.Title"
                              placeholder="Add a note visible to all users…"
                              @bind="NoteText"></textarea>
                    <div class="suggest-note-edit-actions">
                        <button class="suggest-note-save-btn" @onclick="SaveNoteAsync">Save Note</button>
                        <button class="suggest-note-cancel-btn" @onclick="CancelEditNote">Cancel</button>
                    </div>
                </div>
            }
            else if (item.HasAdminNote)
            {
                <!-- Chat bubble -->
                <div class="suggest-note-bubble" role="note" aria-label="Admin note">
                    <div class="suggest-note-bubble-header">
                        <span class="suggest-note-avatar" aria-hidden="true">M</span>
                        <span class="suggest-note-author">Admin</span>
                        @if (IsAdmin)
                        {
                            <button class="suggest-note-edit-btn" aria-label="Edit note for @item.Title" @onclick="() => StartEditNote(item)">
                                <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24" height="12" width="12">
                                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                                </svg>
                            </button>
                        }
                    </div>
                    <p class="suggest-note-text">@item.AdminNote</p>
                </div>
            }

            <div class="suggest-card-footer">
                <div class="suggest-card-votes">
                    <button class="suggest-vote-btn @(item.HasVoted ? "voted" : "")"
                            aria-label="@(item.HasVoted ? "Remove vote from" : "Upvote") @item.Title, @item.Votes votes"
                            aria-pressed="@(item.HasVoted ? "true" : "false")"
                            @onclick="() => ToggleVoteAsync(item)">
                        <svg aria-hidden="true" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 4l-8 8h5v8h6v-8h5z" />
                        </svg>
                        @item.Votes
                    </button>
                </div>
                <div class="suggest-card-actions" role="group" aria-label="Actions">
                    @if (IsAdmin)
                    {
                        <select class="suggest-status-select"
                                aria-label="Change status of @item.Title"
                                value="@item.Status"
                                @onchange="(e) => SetStatusAsync(item.Id, e.Value?.ToString()!)">
                            <option value="New">New</option>
                            <option value="UnderReview">Under Review</option>
                            <option value="InProgress">In Progress</option>
                            <option value="Planned">Planned</option>
                            <option value="Completed">Completed</option>
                            <option value="Declined">Declined</option>
                        </select>
                        @if (!item.HasAdminNote && EditingNoteId != item.Id)
                        {
                            <button class="suggest-add-note-btn" aria-label="Add note to @item.Title" @onclick="() => StartEditNote(item)">
                                <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24" height="14" width="14">
                                    <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
                                </svg>
                            </button>
                        }
                    }
                    @if (item.IsEditable)
                    {
                        <button class="suggest-edit-btn" aria-label="Edit @item.Title" @onclick="() => EditSuggestionAsync(item.Id)">
                            <svg aria-hidden="true" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="2" viewBox="0 0 24 24">
                                <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" />
                                <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" />
                            </svg>
                        </button>
                    }
                </div>
            </div>

        </article>
    }
</div>

<!-- Submit modal -->
@if (ShowSubmitModal)
{
    <div class="suggest-modal-overlay">
        <div class="suggest-modal" role="dialog" aria-modal="true" aria-label="Submit a suggestion">
            <h2>@ModalTitle</h2>
            <div class="suggest-form-group">
                <label class="suggest-form-label" for="suggest-title">Title</label>
                <input class="suggest-form-input" id="suggest-title" type="text" placeholder="e.g. Dark mode support" @bind="NewTitle">
            </div>
            <div class="suggest-form-group">
                <label class="suggest-form-label" for="suggest-desc">Description</label>
                <textarea class="suggest-form-textarea" id="suggest-desc" placeholder="Describe your suggestion in detail..." @bind="NewDescription"></textarea>
            </div>
            <div class="suggest-form-group">
                <label class="suggest-form-label" for="suggest-cat">Category</label>
                <select class="suggest-form-select" id="suggest-cat" @bind="NewCategory">
                    <option value="Feature">Feature</option>
                    <option value="Integration">Integration</option>
                    <option value="Export">Export</option>
                    <option value="UI / UX">UI / UX</option>
                </select>
            </div>
            <div class="suggest-modal-actions">
                <button class="suggest-btn-outline" @onclick="CloseModal">Cancel</button>
                <button class="suggest-btn-submit" @onclick="SubmitSuggestionAsync">@(EditingId.HasValue ? "Save Changes" : "Submit")</button>
            </div>
        </div>
    </div>
}
