@page "/terms"
@layout Layout.LandingLayout
@inherits My.Talli.Web.ViewModels.Pages.TermsViewModel

<PageTitle>Terms of Service — MyTalli</PageTitle>

<a href="#main" class="skip-link">Skip to main content</a>

<div class="policy-page">
    <BrandHeader>
        <a class="back-link" href="@BackLinkHref">@BackLinkText</a>
    </BrandHeader>

    <main id="main">
        <div class="policy-shell">
            <h1 class="page-heading">Terms of Service</h1>
            <p class="page-sub">The agreement between you and MyTalli — last updated @LastUpdated</p>

            <div class="policy-card">
