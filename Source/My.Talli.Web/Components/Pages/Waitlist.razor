@page "/waitlist"
@layout Layout.LandingLayout
@inherits My.Talli.Web.ViewModels.Pages.WaitlistViewModel
@rendermode InteractiveServer

<PageTitle>You're on the Waitlist — MyTalli</PageTitle>

<div class="waitlist-page">
    <!-- Purple swoosh background -->
    <div class="hero-bg">
        <svg preserveAspectRatio="none" viewBox="0 0 1000 600" xmlns="http://www.w3.org/2000/svg">
            <defs>
                <linearGradient id="swooshGrad" x1="0" x2="1" y1="0" y2="1">
                    <stop offset="0%" stop-color="#6c5ce7" />
                    <stop offset="50%" stop-color="#8b5cf6" />
                    <stop offset="100%" stop-color="#6c5ce7" />
                </linearGradient>
            </defs>
            <path d="M0,0 L1000,0 L1000,320 C850,400 650,280 450,340 C250,400 100,360 0,300 Z" fill="url(#swooshGrad)" />
        </svg>
        <div class="deco-circle deco-circle-1"></div>
        <div class="deco-circle deco-circle-2"></div>
        <div class="deco-circle deco-circle-3"></div>
    </div>

    <div class="waitlist-shell">
        <div class="page-header">
            <div class="top-bar">
                <span class="logo">My<span>Talli</span></span>
                <a class="sign-out-btn" href="/api/auth/logout">Sign Out</a>
            </div>

            <div class="confirm-badge">
                <svg fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" viewBox="0 0 24 24">
                    <path d="M22 11.08V12a10 10 0 11-5.93-9.14" />
                    <polyline points="22 4 12 14.01 9 11.01" />
                </svg>
                @if (!string.IsNullOrEmpty(UserName))
                {
                    <text>You're on the waitlist, @UserName!</text>
                }
                else
                {
                    <text>You're on the waitlist!</text>
                }
            </div>

            <h1 class="page-heading">We're building MyTalli</h1>
            <p class="page-sub">Here's where we are on the road to launch. Check back anytime to see our progress.</p>
        </div>

        <div class="timeline">
            @foreach (var milestone in Milestones)
            {
                <div class="timeline-item @(milestone.Status == MilestoneStatus.Upcoming ? "is-upcoming" : "")">
                    @if (milestone.Status == MilestoneStatus.Complete)
                    {
                        <div class="timeline-dot done">
                            <svg fill="none" stroke="#fff" stroke-linecap="round" stroke-linejoin="round" stroke-width="3" viewBox="0 0 24 24">
                                <polyline points="20 6 9 17 4 12" />
                            </svg>
                        </div>
                    }
                    else if (milestone.Status == MilestoneStatus.InProgress)
                    {
                        <div class="timeline-dot in-progress">
                            <svg fill="none" stroke="#fff" stroke-linecap="round" stroke-width="2.5" viewBox="0 0 24 24">
                                <path d="M12 6v6l4 2" />
                            </svg>
                        </div>
                    }
                    else
                    {
                        <div class="timeline-dot upcoming"></div>
                    }

                    <div class="timeline-title">@milestone.Title</div>
                    <div class="timeline-desc">@milestone.Description</div>

                    @if (milestone.Status == MilestoneStatus.Complete)
                    {
                        <span class="timeline-status done">Complete</span>
                    }
                    else if (milestone.Status == MilestoneStatus.InProgress)
                    {
                        <span class="timeline-status in-progress">In Progress</span>
                    }
                    else
                    {
                        <span class="timeline-status upcoming">Upcoming</span>
                    }
                </div>
            }
        </div>

    </div>
</div>
